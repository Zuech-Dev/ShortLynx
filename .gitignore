[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml
# Guard against Windows-style build dirs accidentally created on macOS/Linux as a single
# literal-backslash directory name (e.g. "bin\\Debug"). One of these was committed and broke
# MSBuild wildcard expansion on clean builds (CI + Docker). The escaped backslash matches the literal.
**/bin\\Debug/
**/obj\\Debug/

# Internal business docs — not for the public repo
docs/MASTER_PLAN.md
docs/ANALYTICS_METRICS_PLAN.md
docs/TRACKING_DISCLOSURE_PLAN.md
docs/ELV2_LICENSE_PLAN.md
docs/*

