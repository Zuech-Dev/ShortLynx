{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ShortCode": {
    "Length": 8
  },
  "UrlValidation": {
    "BlocklistPath": ""
  },
  "MagicLink": {
    "TokenExpiryMinutes": 15,
    "ConfirmationUrlBase": ""
  },
  "Email": {
    "Host": "localhost",
    "Port": 587,
    "UseSsl": false,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@example.com",
    "FromName": "ShortLynx"
  },
  "Resend": {
    "_comment": "ApiKey comes from user-secrets (Resend:ApiKey). FromAddress must be a Resend-verified domain in prod; onboarding@resend.dev delivers only to your own account email for local testing.",
    "FromAddress": "onboarding@resend.dev",
    "FromName": "ShortLynx"
  },
  "VisitSink": {
    "ChannelCapacity": 10000,
    "BatchSize": 100,
    "DrainIntervalMs": 500
  },
  "RateLimit": {
    "MagicLinkPermitLimit": 5,
    "MagicLinkWindowSeconds": 300,
    "ApiKeyPermitLimit": 10,
    "ApiKeyWindowSeconds": 300
  }
}
