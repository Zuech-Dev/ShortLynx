{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "sqlite",
    "ConnectionString": "DataSource=shortlynx.db"
  },
  "ApiKey": {
    "HmacSecret": "CHANGE-ME-use-a-32+-char-secret-in-production",
    "AdminSecret": ""
  },
  "ShortCode": {
    "Length": 8
  },
  "UrlValidation": {
    "BlocklistPath": ""
  },
  "MagicLink": {
    "TokenExpiryMinutes": 15,
    "ConfirmationUrlBase": ""
  },
  "Email": {
    "Host": "localhost",
    "Port": 587,
    "UseSsl": false,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@example.com",
    "FromName": "ShortLynx"
  },
  "VisitSink": {
    "ChannelCapacity": 10000,
    "BatchSize": 100,
    "DrainIntervalMs": 500
  },
  "RateLimit": {
    "MagicLinkPermitLimit": 5,
    "MagicLinkWindowSeconds": 300,
    "ApiKeyPermitLimit": 10,
    "ApiKeyWindowSeconds": 300
  }
}
