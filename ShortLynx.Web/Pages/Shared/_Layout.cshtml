<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - ShortLynx</title>
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/ShortLynx.Web.styles.css" asp-append-version="true"/>
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="min-h-screen flex flex-col bg-white text-gray-900">
<header class="border-b bg-white shadow-sm mb-3">
    <nav class="container mx-auto px-4 h-14 flex items-center justify-between">
        <a class="text-lg font-semibold" asp-area="" asp-page="/Index">ShortLynx</a>
        <ul class="flex items-center gap-4">
            <li>
                <a class="text-gray-600 hover:text-gray-900" asp-area="" asp-page="/Privacy">Privacy</a>
            </li>
        </ul>
    </nav>
</header>

<div class="container mx-auto px-4 grow">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-t text-gray-500 mt-8">
    <div class="container mx-auto px-4 py-4 text-sm">
        &copy; @DateTime.Now.Year - ShortLynx.Web -
        <a class="hover:underline" asp-area="" asp-page="/Privacy">Privacy</a> ·
        <a class="hover:underline" asp-area="" asp-page="/DataDeletion">Data Deletion</a>
    </div>
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
