{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Provider": "sqlite",
    "ConnectionString": "DataSource=shortlynx.db"
  },
  "ApiKey": {
    "HmacSecret": "CHANGE-ME-use-a-32+-char-secret-in-production"
  },
  "Admin": {
    "_comment": "Only these emails may sign in. Empty = no one (fail closed). SuperAdminEmails additionally see cross-tenant pages.",
    "AllowedEmails": [],
    "SuperAdminEmails": ["anthony@zuech.dev"]
  },
  "MagicLink": {
    "TokenExpiryMinutes": 15,
    "ConfirmationUrlBase": "https://localhost:7067/auth/confirm"
  },
  "Email": {
    "Host": "localhost",
    "Port": 587,
    "UseSsl": false,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@example.com",
    "FromName": "ShortLynx"
  },
  "Resend": {
    "_comment": "ApiKey comes from user-secrets (Resend:ApiKey). FromAddress must be a Resend-verified domain in prod; onboarding@resend.dev delivers only to your own account email for local testing.",
    "FromAddress": "onboarding@resend.dev",
    "FromName": "ShortLynx"
  }
}
