@page "/users"
@attribute [Authorize(Policy = AdminClaims.SuperAdminPolicy)]
@inject IDbContextFactory<ShortLynxDbContext> DbFactory

<PageTitle>Users — ShortLynx Admin</PageTitle>
<h1 class="text-2xl font-bold mb-4">Users</h1>

@if (!_loaded)
{
    <p class="text-gray-500">Loading…</p>
}
else if (_rows.Count == 0)
{
    <p class="text-gray-500">No users yet.</p>
}
else
{
    <div class="overflow-x-auto">
        <table class="data-table">
            <thead>
            <tr>
                <th>Email</th>
                <th>Status</th>
                <th>Created</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var r in _rows)
            {
                <tr class="@(!r.IsActive ? "text-gray-400" : null)">
                    <td>@r.Email</td>
                    <td>
                        @if (r.IsActive)
                        {
                            <span class="badge badge-green">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-gray">Inactive</span>
                        }
                    </td>
                    <td class="text-gray-500 text-sm whitespace-nowrap">@r.CreatedAt.ToString("yyyy-MM-dd")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="flex gap-2 mt-3">
        <button class="btn btn-outline" @onclick="PrevPage" disabled="@(_page == 1)">← Prev</button>
        <span class="self-center text-gray-500 text-sm">Page @_page</span>
        <button class="btn btn-outline" @onclick="NextPage" disabled="@(_rows.Count < PageSize)">Next →</button>
    </div>
}

@code {
    const int PageSize = 50;
    int _page = 1;
    bool _loaded;
    List<UserRow> _rows = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    async Task LoadAsync()
    {
        _loaded = false;
        await using var db = await DbFactory.CreateDbContextAsync();
        var users = await db.UserAccountEntities
            .OrderByDescending(u => u.Id)
            .Skip((_page - 1) * PageSize)
            .Take(PageSize)
            .ToListAsync();

        _rows = users.Select(u => new UserRow(u.Email, u.IsActive, u.CreatedAt)).ToList();
        _loaded = true;
    }

    async Task PrevPage() { if (_page > 1) { _page--; await LoadAsync(); } }
    async Task NextPage() { _page++; await LoadAsync(); }

    sealed record UserRow(string Email, bool IsActive, DateTimeOffset CreatedAt);
}
