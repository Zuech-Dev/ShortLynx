@page "/settings"
@attribute [Authorize]
@inject IDbContextFactory<ShortLynxDbContext> DbFactory

<PageTitle>Settings — ShortLynx Admin</PageTitle>

<h1 class="text-2xl font-bold mb-3">Settings</h1>

@if (!_loaded)
{
    <p class="text-gray-500">Loading…</p>
}
else
{
    <div class="card mb-4" data-testid="privacy-compliance">
        <div class="card-body">
            <h5 class="card-title">Privacy &amp; Compliance</h5>
            <p class="text-gray-500 text-sm mb-3">
                User-attributed links record per-recipient click attribution, which you are responsible
                for disclosing to your recipients. Until a privacy policy URL is configured here,
                ShortLynx shows recipients its own tracking disclosure before completing those redirects
                — and lets them continue anonymized or decline.
            </p>

            <div class="max-w-[520px] flex flex-col gap-3">
                <div>
                    <label class="field-label">Privacy Policy URL</label>
                    @* Commit per keystroke via oninput. The confirmation checkbox renders only once the
                       URL is non-empty, so the default change event (which waits for the field to lose
                       focus) surfaced the checkbox — and thus the reason Save refused — too late. *@
                    <input class="field-input" type="url" placeholder="https://example.com/privacy"
                           @bind="_privacyUrl" @bind:event="oninput" data-testid="privacy-url"/>
                    <div class="text-xs text-gray-500 mt-1 space-y-1" data-testid="privacy-url-help">
                        <p>
                            <span class="font-medium">No policy of your own yet?</span>
                            You may point this at ShortLynx's own policy —
                            <a class="text-blue-700 hover:underline" href="https://shrtlynx.com/privacy" target="_blank" rel="noopener">shrtlynx.com/privacy</a>
                            — if you agree it accurately describes your use. It discloses exactly the
                            click-attribution these links record. You remain responsible for your own compliance.
                        </p>
                        <p>
                            To serve that policy under <span class="font-medium">your own domain</span>,
                            add it on the <a class="text-blue-700 hover:underline" href="/domains">Domains</a>
                            page and point its DNS at ShortLynx (the same setup you'd use to serve links) —
                            then <code>https://yourdomain/privacy</code> serves the policy automatically.
                        </p>
                        <p>However you configure it, we recommend also linking your privacy policy from your own website.</p>
                    </div>
                </div>
                <div>
                    <label class="field-label">Terms of Service URL <span class="text-gray-400">(optional)</span></label>
                    <input class="field-input" type="url" placeholder="https://example.com/terms"
                           @bind="_termsUrl" data-testid="terms-url"/>
                </div>

                @if (!string.IsNullOrWhiteSpace(_privacyUrl))
                {
                    <label class="inline-flex items-start gap-2 text-sm">
                        <input type="checkbox" class="mt-0.5" @bind="_confirmed" data-testid="privacy-confirm"/>
                        <span>I confirm my privacy policy discloses that links I share may record click
                        attribution data, including device type and general location.</span>
                    </label>
                }

                @if (!_canManageAccount)
                {
                    @* Make the permission boundary visible rather than shipping a silently-disabled
                       button (which reads as "Save is broken"). Owner-only per the roles model. *@
                    <p class="text-amber-700 text-sm" data-testid="privacy-noperm">
                        Only account owners can change these settings.
                    </p>
                }

                <div class="flex items-center gap-3">
                    <button class="btn btn-primary" @onclick="SaveAsync" data-testid="privacy-save" disabled="@(!_canManageAccount)">Save</button>
                    @if (_saved)
                    {
                        <span class="text-green-600 text-sm" data-testid="privacy-saved">Saved.</span>
                    }
                    @if (_error is not null)
                    {
                        <span class="text-red-600 text-sm" data-testid="privacy-error">@_error</span>
                    }
                </div>

                @if (_hasPolicy)
                {
                    <div class="text-sm text-green-700" data-testid="privacy-configured">
                        ✓ Privacy policy configured — recipients will not see a ShortLynx disclosure interstitial.
                    </div>
                }
                else
                {
                    <div class="text-sm text-amber-700" data-testid="privacy-missing">
                        Recipients of your user-attributed links currently see the ShortLynx tracking
                        disclosure before the redirect completes.
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    bool _loaded, _saved, _confirmed, _hasPolicy, _canManageAccount;
    string? _privacyUrl, _termsUrl, _error;
    Guid _accountId;

    protected override async Task OnInitializedAsync()
    {
        var principal = (await AuthState).User;
        await using var db = await DbFactory.CreateDbContextAsync();
        var ctx = await AccountRoleContext.ResolveAsync(db, principal);
        if (ctx is null) return;
        _accountId = ctx.AccountId;
        // Policy/terms URLs are the operator's disclosure assertion (P3/P4) — account-level
        // configuration, so Owner-gated (ManageAccount), not ManageResources.
        _canManageAccount = ctx.CanManageAccount;

        var account = await db.AccountEntities.FirstAsync(a => a.Id == _accountId);
        _privacyUrl = account.PrivacyPolicyUrl;
        _termsUrl = account.TermsOfServiceUrl;
        _hasPolicy = !string.IsNullOrWhiteSpace(_privacyUrl);
        _confirmed = _hasPolicy; // an already-saved URL was confirmed when it was saved
        _loaded = true;
    }

    async Task SaveAsync()
    {
        // Handler-level guard, not just disabled UI — Blazor Server executes handlers regardless of markup.
        if (!_canManageAccount) return;
        _saved = false;
        _error = null;

        var privacy = Normalize(_privacyUrl);
        var terms = Normalize(_termsUrl);

        if (privacy is not null && !IsHttpsUrl(privacy)) { _error = "Privacy policy must be an https:// URL."; return; }
        if (terms is not null && !IsHttpsUrl(terms)) { _error = "Terms of service must be an https:// URL."; return; }
        // The confirmation is the operator's assertion of disclosure — the URL is not accepted without it.
        if (privacy is not null && !_confirmed) { _error = "Please confirm your policy discloses link tracking."; return; }

        await using var db = await DbFactory.CreateDbContextAsync();
        var account = await db.AccountEntities.FirstAsync(a => a.Id == _accountId);
        account.PrivacyPolicyUrl = privacy;
        account.TermsOfServiceUrl = terms;
        await db.SaveChangesAsync();

        _hasPolicy = privacy is not null;
        _saved = true;
    }

    static string? Normalize(string? url)
        => string.IsNullOrWhiteSpace(url) ? null : url.Trim();

    static bool IsHttpsUrl(string url)
        => Uri.TryCreate(url, UriKind.Absolute, out var u) && u.Scheme == Uri.UriSchemeHttps;
}
