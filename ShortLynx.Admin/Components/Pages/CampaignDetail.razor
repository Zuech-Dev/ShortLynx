@page "/campaigns/{Id:guid}"
@attribute [Authorize]
@using Microsoft.Extensions.DependencyInjection
@using ShortLynx.Services.Analytics
@using ShortLynx.Services.Campaigns
@inject IServiceScopeFactory ScopeFactory
@inject IDbContextFactory<ShortLynxDbContext> DbFactory

<PageTitle>Campaign — ShortLynx Admin</PageTitle>

@if (_notFound)
{
    <p class="text-red-600">Campaign not found.</p>
    <a href="/campaigns" class="btn btn-outline">← Back to Campaigns</a>
}
else if (!_loaded)
{
    <p class="text-gray-500">Loading…</p>
}
else
{
    <div class="flex items-center gap-2 mb-3">
        <a href="/campaigns" class="btn btn-outline">← Back</a>
        <h1 class="text-xl font-bold">@_name</h1>
        <span class="badge badge-gray">@_links.Count link@(_links.Count == 1 ? "" : "s")</span>
    </div>

    @if (_engagement is { RecipientsTotal: > 0 } e)
    {
        <div class="card mb-4" data-testid="recipient-engagement">
            <div class="card-body">
                <h5 class="card-title">Recipient engagement</h5>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                    <div>
                        <div class="text-2xl font-bold" data-testid="click-rate">@ClickRatePct(e)%</div>
                        <div class="text-gray-500 text-sm">Click rate</div>
                    </div>
                    <div>
                        <div class="text-2xl font-bold" data-testid="recipients-clicked">@e.RecipientsClicked <span class="text-base font-normal text-gray-500">of @e.RecipientsTotal</span></div>
                        <div class="text-gray-500 text-sm">Recipients clicked</div>
                    </div>
                    <div>
                        <div class="text-sm font-medium">@FormatMinutes(e.MedianTimeToFirstClickMinutes)</div>
                        <div class="text-gray-500 text-sm" title="Half of the recipients who clicked did so within this time of their code being created.">Median time to click</div>
                    </div>
                    <div>
                        <div class="text-sm font-medium">@FormatMinutes(e.P90TimeToFirstClickMinutes)</div>
                        <div class="text-gray-500 text-sm" title="90% of the recipients who clicked did so within this time of their code being created.">p90 time to click</div>
                    </div>
                </div>
            </div>
        </div>
    }

    <ClickBreakdownCard Breakdown="_breakdown" Title="Campaign clicks" />

    @if (_breakdown is { TotalClicks: > 0 })
    {
        <div class="mb-4 -mt-2">
            <a class="btn btn-outline" href="/export/campaign/@Id" download data-testid="export-csv"
               title="Aggregate statistics only — the same breakdowns shown above, never individual clicks.">Download CSV</a>
        </div>
    }

    @if (_breakdown is null || _breakdown.TotalClicks == 0)
    {
        <p class="text-gray-500" data-testid="no-clicks">No clicks recorded for this campaign yet.</p>
    }

    @if (_links.Count > 0)
    {
        <h5 class="text-base font-semibold mb-2">Links in this campaign</h5>
        <table class="data-table" data-testid="link-table">
            <thead>
            <tr><th>URL</th><th>Mode</th><th class="text-right">Clicks</th><th class="text-right">Unique</th></tr>
            </thead>
            <tbody>
            @foreach (var l in _links)
            {
                <tr>
                    <td class="truncate max-w-[360px]"><a class="text-blue-700 hover:underline" href="/links/@l.Id">@l.Url</a></td>
                    <td>@l.Mode</td>
                    <td class="text-right">@l.TotalClicks</td>
                    <td class="text-right">@l.UniqueClicks</td>
                </tr>
            }
            </tbody>
        </table>
    }
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;
    [Parameter] public Guid Id { get; set; }

    bool _loaded, _notFound, _authResolved;
    Guid _uid, _accountId;
    string _name = string.Empty;
    ClickBreakdown? _breakdown;
    RecipientEngagementStats? _engagement;
    List<LinkRow> _links = [];

    protected override async Task OnParametersSetAsync()
    {
        if (!_authResolved)
        {
            var principal = (await AuthState).User;
            var userId = principal.GetUserId();
            if (userId is null) { _notFound = true; _loaded = true; return; }
            _uid = userId.Value;
            await using (var db = await DbFactory.CreateDbContextAsync())
                _accountId = await AccountResolver.ResolveAccountIdAsync(db, _uid, principal.GetAccountId(), principal.Identity?.Name ?? "Personal");
            _authResolved = true;
        }
        await LoadAsync();
    }

    async Task LoadAsync()
    {
        _loaded = false;
        _notFound = false;

        ShortLynx.Data.Entities.CampaignEntity? campaign;
        await using (var scope = ScopeFactory.CreateAsyncScope())
        {
            var svc = scope.ServiceProvider.GetRequiredService<ICampaignService>();
            campaign = await svc.GetAsync(Id, _accountId);
        }
        if (campaign is null) { _notFound = true; _loaded = true; return; }
        _name = campaign.Name;

        await using var db = await DbFactory.CreateDbContextAsync();

        var links = await db.LinkEntities
            .Where(l => l.CampaignId == Id && l.AccountId == _accountId)
            .Select(l => new { l.Id, l.OriginalUrl, l.Mode })
            .ToListAsync();
        var linkIds = links.Select(l => l.Id).ToList();

        // (linkId, row) across both link modes: anonymous short codes → Visits, recipient codes → UserVisits.
        var tagged = new List<(Guid LinkId, VisitRow Row)>();

        var scToLink = await db.ShortCodeEntities
            .Where(sc => linkIds.Contains(sc.LinkId))
            .Select(sc => new { sc.Id, sc.LinkId })
            .ToDictionaryAsync(x => x.Id, x => x.LinkId);
        if (scToLink.Count > 0)
        {
            var scIds = scToLink.Keys.ToList();
            var visits = await db.VisitEntities
                .Where(v => scIds.Contains(v.ShortCodeId))
                .Select(v => new { v.ShortCodeId, v.HashedIp, v.Source, v.Device, v.ClickedAt, v.Browser, v.Os, v.Country, v.Language, v.NavigationType, v.TimeZone, v.UtmSource, v.UtmMedium, v.UtmCampaign })
                .ToListAsync();
            tagged.AddRange(visits.Select(v =>
                (scToLink[v.ShortCodeId], new VisitRow(v.HashedIp, v.Source, v.Device, v.ClickedAt, v.Browser, v.Os, v.Country, v.Language, v.NavigationType, v.TimeZone, v.UtmSource, v.UtmMedium, v.UtmCampaign))));
        }

        var codeToLink = await db.UserLinkCodeEntities
            .Where(c => linkIds.Contains(c.LinkId))
            .Select(c => new { c.Id, c.LinkId })
            .ToDictionaryAsync(x => x.Id, x => x.LinkId);
        if (codeToLink.Count > 0)
        {
            var codeIds = codeToLink.Keys.ToList();
            var uvisits = await db.UserVisitEntities
                .Where(v => codeIds.Contains(v.UserLinkCodeId))
                .Select(v => new { v.UserLinkCodeId, v.HashedIp, v.Source, v.Device, v.ClickedAt, v.Browser, v.Os, v.Country, v.Language, v.NavigationType, v.TimeZone, v.UtmSource, v.UtmMedium, v.UtmCampaign })
                .ToListAsync();
            tagged.AddRange(uvisits.Select(v =>
                (codeToLink[v.UserLinkCodeId], new VisitRow(v.HashedIp, v.Source, v.Device, v.ClickedAt, v.Browser, v.Os, v.Country, v.Language, v.NavigationType, v.TimeZone, v.UtmSource, v.UtmMedium, v.UtmCampaign))));
        }

        _breakdown = ClickAggregator.Summarize(tagged.Select(x => x.Row).ToList());

        // Mode 2 recipient engagement: join each provisioned code to its earliest visit.
        var engagementCodes = await db.UserLinkCodeEntities
            .Where(c => linkIds.Contains(c.LinkId))
            .Select(c => new { c.Id, c.CreatedAt })
            .ToListAsync();
        // Grouped client-side: SQLite (dev/tests) cannot translate Min over DateTimeOffset.
        var engCodeIds = engagementCodes.Select(c => c.Id).ToList();
        var firstClicks = (await db.UserVisitEntities
                .Where(v => engCodeIds.Contains(v.UserLinkCodeId))
                .Select(v => new { v.UserLinkCodeId, v.ClickedAt })
                .ToListAsync())
            .GroupBy(v => v.UserLinkCodeId)
            .ToDictionary(g => g.Key, g => g.Min(v => v.ClickedAt));
        _engagement = RecipientEngagement.Compute(engagementCodes
            .Select(c => (c.CreatedAt, firstClicks.TryGetValue(c.Id, out var f) ? f : (DateTimeOffset?)null))
            .ToList());

        var byLink = tagged.ToLookup(x => x.LinkId, x => x.Row);
        _links = links
            .Select(l =>
            {
                var rows = byLink[l.Id].ToList();
                return new LinkRow(l.Id, l.OriginalUrl, l.Mode.ToString(),
                    rows.Count, rows.Select(r => r.HashedIp).Distinct().Count());
            })
            .OrderByDescending(l => l.TotalClicks)
            .ToList();

        _loaded = true;
    }

    sealed record LinkRow(Guid Id, string Url, string Mode, long TotalClicks, long UniqueClicks);

    static int ClickRatePct(RecipientEngagementStats e)
        => e.RecipientsTotal == 0 ? 0 : (int)Math.Round(100.0 * e.RecipientsClicked / e.RecipientsTotal);

    // Human-friendly duration for the time-to-first-click percentiles: minutes under an hour,
    // hours under two days, days beyond that. "—" until any recipient has clicked.
    static string FormatMinutes(double? minutes) => minutes switch
    {
        null => "—",
        < 1 => "< 1 min",
        < 60 => $"{minutes:0} min",
        < 2880 => $"{minutes / 60:0.#} h",
        _ => $"{minutes / 1440:0.#} d",
    };
}
