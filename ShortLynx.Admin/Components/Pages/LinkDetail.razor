@page "/links/{Id:guid}"
@attribute [Authorize]
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Options
@using ShortLynx.Services.Analytics
@using ShortLynx.Services.Links
@inject IDbContextFactory<ShortLynxDbContext> DbFactory
@inject IServiceScopeFactory ScopeFactory
@inject IOptions<DashboardOptions> DashboardOpts
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Link Detail — ShortLynx Admin</PageTitle>

@if (_notFound)
{
    <p class="text-red-600">Link not found.</p>
    <a href="/links" class="btn btn-outline">← Back to Links</a>
}
else if (!_loaded)
{
    <p class="text-gray-500">Loading…</p>
}
else
{
    <div class="flex items-center gap-2 mb-3">
        <a href="/links" class="btn btn-outline">← Back</a>
        <h1 class="text-xl font-bold">Link Detail</h1>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <dl class="grid grid-cols-1 sm:grid-cols-[8rem_1fr] gap-x-4 gap-y-2 mb-0">
                <dt class="font-medium text-gray-500">URL</dt>
                <dd><a class="text-blue-700 hover:underline" href="@_link!.OriginalUrl" target="_blank" rel="noopener">@_link.OriginalUrl</a></dd>

                <dt class="font-medium text-gray-500">Short Code</dt>
                <dd><code>@_shortCode</code></dd>

                <dt class="font-medium text-gray-500">Mode</dt>
                <dd>@_link.Mode</dd>

                <dt class="font-medium text-gray-500">API Key</dt>
                <dd>@(_link.ApiKey?.Name ?? "—")</dd>

                <dt class="font-medium text-gray-500">Created</dt>
                <dd>@_link.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</dd>
            </dl>
        </div>
    </div>

    @if (_link.Mode == LinkMode.Anonymous && !string.IsNullOrEmpty(_shortCode))
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">QR code</h5>
                <p class="text-gray-500 text-sm">Download a QR code that opens this short link — PNG for embedding or print, SVG for scalable use.</p>
                <div class="flex items-center gap-4">
                    <img src="/qr/@Id?format=svg" alt="QR code for this link" width="140" height="140"
                         class="border border-gray-200 rounded" data-testid="qr-preview"/>
                    <div class="flex flex-col gap-2">
                        <a class="btn btn-primary" href="/qr/@Id?format=png" download data-testid="qr-png">Download PNG</a>
                        <a class="btn btn-outline" href="/qr/@Id?format=svg" download data-testid="qr-svg">Download SVG</a>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_canPin)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Custom domain</h5>
                <p class="text-gray-500 text-sm">Pin this link to one of your verified domains, or leave it on any host.</p>
                <div class="flex gap-2 items-center max-w-[520px]">
                    <select class="field-input" @bind="_selectedDomainKey" data-testid="pin-select">
                        <option value="">Any host (no pin)</option>
                        @foreach (var d in _verifiedDomains)
                        {
                            <option value="@d.Id">@d.Domain</option>
                        }
                    </select>
                    <button class="btn btn-primary" data-testid="pin-save" @onclick="SavePin">Save</button>
                </div>
                @if (_verifiedDomains.Count == 0)
                {
                    <div class="text-sm text-gray-500 mt-1">No verified domains yet — add one under <a class="text-blue-700 hover:underline" href="/domains">Domains</a>.</div>
                }
                @if (_pinSaved)
                {
                    <div class="text-green-600 text-sm mt-1" data-testid="pin-saved">Saved.</div>
                }
            </div>
        </div>
    }

    @if (_breakdown is { TotalClicks: > 0 } b)
    {
        <div class="card mb-4" data-testid="click-breakdown">
            <div class="card-body">
                <h5 class="card-title">Click breakdown</h5>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
                    <div><div class="text-2xl font-bold" data-testid="total-clicks">@b.TotalClicks</div><div class="text-gray-500 text-sm">Total clicks</div></div>
                    <div>
                        <div class="text-2xl font-bold" data-testid="unique-clicks">@b.UniqueClicks</div>
                        <div class="text-gray-500 text-sm" title="Distinct hashed IPs. The hash rotates hourly for privacy, so this dedupes repeat clicks within an hour rather than counting lifetime-unique visitors.">Unique (per hr)</div>
                    </div>
                    <div><div class="text-sm font-medium">@(b.FirstClickAt?.ToString("yyyy-MM-dd") ?? "—")</div><div class="text-gray-500 text-sm">First click</div></div>
                    <div><div class="text-sm font-medium">@(b.LastClickAt?.ToString("yyyy-MM-dd") ?? "—")</div><div class="text-gray-500 text-sm">Last click</div></div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div data-testid="sources">
                        <h6 class="font-semibold text-sm mb-2">By platform</h6>
                        @foreach (var s in b.Sources)
                        {
                            <div class="flex items-center gap-2 text-sm mb-1">
                                <span class="w-24 shrink-0 truncate">@s.Source</span>
                                <span class="flex-1 bg-gray-100 rounded h-3"><span class="block bg-blue-500 h-3 rounded" style="width:@BarPct(s.Count, b.TotalClicks)%"></span></span>
                                <span class="w-10 text-right text-gray-600">@s.Count</span>
                            </div>
                        }
                    </div>
                    <div data-testid="devices">
                        <h6 class="font-semibold text-sm mb-2">By device</h6>
                        @foreach (var d in b.Devices)
                        {
                            <div class="flex items-center gap-2 text-sm mb-1">
                                <span class="w-24 shrink-0 truncate">@d.Device</span>
                                <span class="flex-1 bg-gray-100 rounded h-3"><span class="block bg-green-500 h-3 rounded" style="width:@BarPct(d.Count, b.TotalClicks)%"></span></span>
                                <span class="w-10 text-right text-gray-600">@d.Count</span>
                            </div>
                        }
                    </div>
                </div>

                @if (b.Timeline.Count > 0)
                {
                    var tlMax = b.Timeline.Max(t => t.Count);
                    <div class="mt-4" data-testid="timeline">
                        <h6 class="font-semibold text-sm mb-2">Clicks by day (last 30)</h6>
                        <div class="flex items-end gap-1 h-24">
                            @foreach (var day in b.Timeline.TakeLast(30))
                            {
                                <div class="flex-1 bg-blue-400 rounded-t min-h-[2px]"
                                     style="height:@BarPct(day.Count, tlMax)%"
                                     title="@day.Date.ToString("yyyy-MM-dd"): @day.Count click(s)"></div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (_link.Mode == LinkMode.Anonymous)
    {
        <h5 class="text-base font-semibold mb-2">Recent clicks</h5>

        @if (_recentVisits.Count > 0)
        {
            <table class="data-table">
                <thead>
                <tr><th>Clicked At</th><th>Referrer</th></tr>
                </thead>
                <tbody>
                @foreach (var v in _recentVisits)
                {
                    <tr>
                        <td class="whitespace-nowrap">@v.ClickedAt.ToString("yyyy-MM-dd HH:mm") UTC</td>
                        <td class="text-gray-500 text-sm truncate max-w-[300px]">@(v.Referrer ?? "—")</td>
                    </tr>
                }
                </tbody>
            </table>
            @if (_totalClicks > 50)
            {
                <p class="text-gray-500 text-sm mt-1">Showing 50 most recent clicks.</p>
            }
        }
    }
    else
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Provision codes</h5>
                <p class="text-gray-500 text-sm">One recipient per line (e.g. an email or campaign tag). A unique short code is minted for each.</p>
                <EditForm Model="_provision" OnValidSubmit="ProvisionCodes">
                    <div class="mb-2">
                        <InputTextArea class="field-input font-mono" rows="4" @bind-Value="_provision.Recipients"
                                       placeholder="alice@example.com&#10;bob@example.com" data-testid="provision-input"/>
                    </div>
                    <label class="inline-flex items-center gap-2 mb-2" for="one-time">
                        <InputCheckbox id="one-time" @bind-Value="_provision.IsOneTimeUse"/>
                        <span>One-time use <span class="text-gray-500 text-sm">— each code redirects only once</span></span>
                    </label>
                    @if (_provisionError is not null)
                    {
                        <div class="text-red-600 text-sm mb-2" data-testid="provision-error">@_provisionError</div>
                    }
                    <div>
                        <button type="submit" class="btn btn-primary" data-testid="provision-submit">Provision codes</button>
                    </div>
                </EditForm>

                @if (_minted.Count > 0)
                {
                    <div class="alert alert-success mt-3" data-testid="minted">
                        <div class="flex items-center mb-2">
                            <span class="font-semibold">@_minted.Count code(s) ready.</span>
                            <button class="btn btn-outline-success ml-auto" @onclick="CopyAllMinted">Copy all</button>
                        </div>
                        <ul class="text-sm font-mono space-y-0.5">
                            @foreach (var m in _minted)
                            {
                                <li>@(m.Recipient ?? "—") → <a class="text-blue-700 hover:underline" href="@m.Url" target="_blank" rel="noopener">@m.Url</a></li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>

        <h5 class="text-base font-semibold mb-2">User Code Analytics</h5>
        @if (_userRows.Count == 0)
        {
            <p class="text-gray-500">No user codes provisioned yet.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                <tr><th>Recipient</th><th>Code</th><th class="text-right">Clicks</th><th>QR</th></tr>
                </thead>
                <tbody>
                @foreach (var r in _userRows)
                {
                    <tr>
                        <td>@(r.Recipient ?? "—") @if (r.IsOneTimeUse) { <span class="badge badge-yellow">one-time</span> }</td>
                        <td><code>@r.Code</code></td>
                        <td class="text-right">@r.Clicks</td>
                        <td class="whitespace-nowrap text-sm">
                            <a class="text-blue-700 hover:underline" href="/qr/@Id?format=png&code=@r.Code" download data-testid="qr-code-png">PNG</a>
                            <span class="text-gray-300">·</span>
                            <a class="text-blue-700 hover:underline" href="/qr/@Id?format=svg&code=@r.Code" download>SVG</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    }
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;
    [Parameter] public Guid Id { get; set; }

    bool _loaded, _notFound;
    bool _authResolved, _isSuperAdmin;
    Guid _uid;
    LinkEntity? _link;
    string _shortCode = string.Empty;
    int _totalClicks;
    List<VisitEntity> _recentVisits = [];
    List<UserCodeRow> _userRows = [];
    ClickBreakdown? _breakdown;

    // Bar width as a percent of a basis (total clicks, or the busiest day for the timeline). Clamped 0–100.
    static int BarPct(long count, long basis) => basis <= 0 ? 0 : (int)Math.Clamp(Math.Round(100.0 * count / basis), 0, 100);

    // Custom-domain pinning (current-account links only).
    bool _canPin, _pinSaved;
    Guid _accountId;
    List<DomainOption> _verifiedDomains = [];
    string _selectedDomainKey = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        if (!_authResolved)
        {
            var principal = (await AuthState).User;
            _isSuperAdmin = principal.IsSuperAdmin();
            var userId = principal.GetUserId();
            if (userId is null) { _notFound = true; _loaded = true; return; }
            _uid = userId.Value;
            await using (var db = await DbFactory.CreateDbContextAsync())
                _accountId = await AccountResolver.ResolveAccountIdAsync(db, _uid, principal.GetAccountId(), principal.Identity?.Name ?? "Personal");
            _authResolved = true;
        }
        await LoadAsync();
    }

    async Task LoadAsync()
    {
        _loaded = false;
        _notFound = false;
        _breakdown = null;

        await using var db = await DbFactory.CreateDbContextAsync();

        _link = await db.LinkEntities
            .Include(l => l.ApiKey)
            .FirstOrDefaultAsync(l => l.Id == Id);

        if (_link is null) { _notFound = true; _loaded = true; return; }

        // Ownership: members may only view links in their account; super-admins may view any.
        // Report "not found" (not "forbidden") so existence isn't leaked.
        if (!_isSuperAdmin && _link.AccountId != _accountId)
        {
            _link = null;
            _notFound = true;
            _loaded = true;
            return;
        }

        if (_link.Mode == LinkMode.Anonymous)
        {
            var sc = await db.ShortCodeEntities.FirstOrDefaultAsync(s => s.LinkId == Id);
            _shortCode = sc?.Code ?? string.Empty;

            if (sc is not null)
            {
                _totalClicks = await db.VisitEntities.CountAsync(v => v.ShortCodeId == sc.Id);
                _recentVisits = await db.VisitEntities
                    .Where(v => v.ShortCodeId == sc.Id)
                    .OrderByDescending(v => v.Id)
                    .Take(50)
                    .ToListAsync();
                var rows = (await db.VisitEntities.Where(v => v.ShortCodeId == sc.Id)
                        .Select(v => new { v.HashedIp, v.Source, v.Device, v.ClickedAt }).ToListAsync())
                    .Select(v => new VisitRow(v.HashedIp, v.Source, v.Device, v.ClickedAt)).ToList();
                _breakdown = ClickAggregator.Summarize(rows);
            }
        }
        else
        {
            var codes = await db.UserLinkCodeEntities
                .Where(c => c.LinkId == Id)
                .OrderByDescending(c => c.Id)
                .ToListAsync();

            var codeIds = codes.Select(c => c.Id).ToList();
            var clicks = await db.UserVisitEntities
                .Where(v => codeIds.Contains(v.UserLinkCodeId))
                .GroupBy(v => v.UserLinkCodeId)
                .Select(g => new { Id = g.Key, Count = g.Count() })
                .ToListAsync();

            var clickMap = clicks.ToDictionary(x => x.Id, x => x.Count);
            _userRows = codes.Select(c => new UserCodeRow(c.Code, c.Recipient, c.IsOneTimeUse,
                clickMap.GetValueOrDefault(c.Id, 0))).ToList();

            var mrows = (await db.UserVisitEntities.Where(v => codeIds.Contains(v.UserLinkCodeId))
                    .Select(v => new { v.HashedIp, v.Source, v.Device, v.ClickedAt }).ToListAsync())
                .Select(v => new VisitRow(v.HashedIp, v.Source, v.Device, v.ClickedAt)).ToList();
            _breakdown = ClickAggregator.Summarize(mrows);
        }

        // Pinning is offered for links in the current account (not when a super-admin views another's).
        _canPin = _link.AccountId == _accountId;
        if (_canPin)
        {
            _verifiedDomains = await db.CustomDomainEntities
                .Where(d => d.AccountId == _accountId && d.VerificationStatus == DomainVerificationStatus.Verified)
                .OrderBy(d => d.Domain)
                .Select(d => new DomainOption(d.Id, d.Domain))
                .ToListAsync();
            _selectedDomainKey = _link.CustomDomainId?.ToString() ?? string.Empty;
        }

        _loaded = true;
    }

    async Task SavePin()
    {
        if (!_canPin) return;
        _pinSaved = false;
        Guid? domainId = Guid.TryParse(_selectedDomainKey, out var id) ? id : null;

        await using var scope = ScopeFactory.CreateAsyncScope();
        var svc = scope.ServiceProvider.GetRequiredService<ILinkService>();
        if (await svc.SetLinkDomainAsync(Id, domainId, _accountId))
        {
            _pinSaved = true;
            await LoadAsync();
        }
    }

    sealed record DomainOption(Guid Id, string Domain);

    // ── Code provisioning (Mode 2) ────────────────────────────────────────────

    readonly ProvisionForm _provision = new();
    string? _provisionError;
    List<MintedCode> _minted = [];

    async Task ProvisionCodes()
    {
        _provisionError = null;

        var recipients = (_provision.Recipients ?? string.Empty)
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(label => new CodeRecipient(Guid.CreateVersion7(), label))
            .ToList();

        if (recipients.Count == 0)
        {
            _provisionError = "Enter at least one recipient.";
            return;
        }

        await using var scope = ScopeFactory.CreateAsyncScope();
        var svc = scope.ServiceProvider.GetRequiredService<ILinkService>();
        var codes = await svc.CreateUserLinkCodesAsync(Id, recipients, _provision.IsOneTimeUse);

        var baseUrl = DashboardOpts.Value;
        _minted = codes.Select(c => new MintedCode(c.Recipient, baseUrl.BuildShortUrl(c.Code))).ToList();
        _provision.Recipients = string.Empty;
        await LoadAsync();
    }

    async Task CopyAllMinted()
    {
        var text = string.Join('\n', _minted.Select(m => m.Url));
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    sealed class ProvisionForm
    {
        public string? Recipients { get; set; }
        public bool IsOneTimeUse { get; set; }
    }

    sealed record MintedCode(string? Recipient, string Url);

    sealed record UserCodeRow(string Code, string? Recipient, bool IsOneTimeUse, int Clicks);
}
