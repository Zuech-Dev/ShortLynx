@page "/campaigns"
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.DependencyInjection
@using ShortLynx.Services.Campaigns
@inject IServiceScopeFactory ScopeFactory
@inject IDbContextFactory<ShortLynxDbContext> DbFactory

<PageTitle>Campaigns — ShortLynx Admin</PageTitle>

<div class="flex justify-between items-center mb-3">
    <h1 class="text-2xl font-bold">Campaigns</h1>
    <button class="btn btn-primary" data-testid="new-campaign" @onclick="() => _showAdd = !_showAdd">
        @(_showAdd ? "Cancel" : "+ New campaign")
    </button>
</div>

<p class="text-gray-500 text-sm mb-3 max-w-[640px]">
    Group links so their clicks roll up into one report. An optional UTM template is appended to each
    assigned link's destination at redirect time, so downstream analytics (GA, etc.) attribute the traffic.
    Assign a link to a campaign from its detail page.
</p>

@if (_showAdd)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">New campaign</h5>
            <EditForm Model="_form" OnValidSubmit="Create">
                <DataAnnotationsValidator/>
                @CampaignFields(_form)
                @if (_addError is not null)
                {
                    <div class="text-red-600 text-sm mb-2" data-testid="add-error">@_addError</div>
                }
                <button type="submit" class="btn btn-primary" data-testid="add-submit">Create campaign</button>
            </EditForm>
        </div>
    </div>
}

@if (!_loaded)
{
    <p class="text-gray-500">Loading…</p>
}
else if (_campaigns.Count == 0)
{
    <p class="text-gray-500" data-testid="empty">No campaigns yet.</p>
}
else
{
    <div class="flex flex-col gap-3">
        @foreach (var c in _campaigns)
        {
            <div class="card" data-testid="campaign-row">
                <div class="card-body">
                    @if (_editingId == c.Id)
                    {
                        <EditForm Model="_edit" OnValidSubmit="SaveEdit">
                            <DataAnnotationsValidator/>
                            @CampaignFields(_edit)
                            <div class="flex gap-2">
                                <button type="submit" class="btn btn-primary" data-testid="edit-save">Save</button>
                                <button type="button" class="btn btn-outline" @onclick="() => _editingId = null">Cancel</button>
                            </div>
                        </EditForm>
                    }
                    else
                    {
                        <div class="flex items-center gap-2 mb-1">
                            <span class="font-semibold">@c.Name</span>
                            <span class="badge badge-gray" data-testid="link-count">@c.LinkCount link@(c.LinkCount == 1 ? "" : "s")</span>
                            <div class="ml-auto flex gap-2">
                                <a class="btn btn-outline-primary" href="/campaigns/@c.Id" data-testid="view-analytics">Analytics</a>
                                <button class="btn btn-outline" data-testid="edit-btn" @onclick="() => BeginEdit(c)">Edit</button>
                                <button class="btn btn-outline-danger" data-testid="remove-btn" disabled="@_busy" @onclick="() => Remove(c.Id)">Delete</button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(c.Description))
                        {
                            <p class="text-gray-600 text-sm mb-1">@c.Description</p>
                        }
                        @if (c.HasUtm)
                        {
                            <div class="text-xs text-gray-500 font-mono">
                                @($"utm_source={c.UtmSource} utm_medium={c.UtmMedium} utm_campaign={c.UtmCampaign}")
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    bool _loaded, _resolved, _showAdd, _busy;
    Guid _uid, _accountId;
    Guid? _editingId;
    List<CampaignRow> _campaigns = [];
    readonly CampaignForm _form = new();
    readonly CampaignForm _edit = new();
    string? _addError;

    // Shared name/description/UTM inputs for both the create and edit forms.
    private RenderFragment CampaignFields(CampaignForm f) =>@<text>
        <div class="mb-2">
            <label class="field-label">Name</label>
            <InputText class="field-input" @bind-Value="f.Name" data-testid="name-input"/>
            <ValidationMessage For="() => f.Name"/>
        </div>
        <div class="mb-2">
            <label class="field-label">Description</label>
            <InputText class="field-input" @bind-Value="f.Description"/>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 mb-3">
            <div><label class="field-label">utm_source</label><InputText class="field-input" @bind-Value="f.UtmSource"/></div>
            <div><label class="field-label">utm_medium</label><InputText class="field-input" @bind-Value="f.UtmMedium"/></div>
            <div><label class="field-label">utm_campaign</label><InputText class="field-input" @bind-Value="f.UtmCampaign"/></div>
        </div>
    </text>;

    protected override async Task OnInitializedAsync()
    {
        var principal = (await AuthState).User;
        var userId = principal.GetUserId();
        if (userId is null) { _loaded = true; return; }
        _uid = userId.Value;
        await using (var db = await DbFactory.CreateDbContextAsync())
            _accountId = await AccountResolver.ResolveAccountIdAsync(db, _uid, principal.GetAccountId(), principal.Identity?.Name ?? "Personal");
        _resolved = true;
        await LoadAsync();
    }

    async Task LoadAsync()
    {
        if (!_resolved) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var counts = await db.LinkEntities
            .Where(l => l.AccountId == _accountId && l.CampaignId != null)
            .GroupBy(l => l.CampaignId!.Value)
            .Select(g => new { g.Key, Count = g.Count() })
            .ToDictionaryAsync(x => x.Key, x => x.Count);

        await using var scope = ScopeFactory.CreateAsyncScope();
        var svc = scope.ServiceProvider.GetRequiredService<ICampaignService>();
        var list = await svc.ListAsync(_accountId);
        _campaigns = list.Select(c => new CampaignRow(
            c.Id, c.Name, c.Description, c.UtmSource, c.UtmMedium, c.UtmCampaign,
            counts.GetValueOrDefault(c.Id, 0))).ToList();
        _loaded = true;
    }

    async Task Create()
    {
        if (!_resolved) return;
        _addError = null;
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var svc = scope.ServiceProvider.GetRequiredService<ICampaignService>();
            await svc.CreateAsync(_accountId, _form.ToInput(), _uid);
            _form.Reset();
            _showAdd = false;
            await LoadAsync();
        }
        catch (ArgumentException ex) { _addError = ex.Message; }
    }

    void BeginEdit(CampaignRow c)
    {
        _editingId = c.Id;
        _edit.Name = c.Name;
        _edit.Description = c.Description;
        _edit.UtmSource = c.UtmSource;
        _edit.UtmMedium = c.UtmMedium;
        _edit.UtmCampaign = c.UtmCampaign;
    }

    async Task SaveEdit()
    {
        if (_editingId is not { } id) return;
        await using var scope = ScopeFactory.CreateAsyncScope();
        var svc = scope.ServiceProvider.GetRequiredService<ICampaignService>();
        await svc.UpdateAsync(id, _accountId, _edit.ToInput());
        _editingId = null;
        await LoadAsync();
    }

    async Task Remove(Guid id)
    {
        _busy = true;
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var svc = scope.ServiceProvider.GetRequiredService<ICampaignService>();
            await svc.DeleteAsync(id, _accountId);
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    sealed class CampaignForm
    {
        [Required(ErrorMessage = "Name is required.")]
        public string? Name { get; set; }
        public string? Description { get; set; }
        public string? UtmSource { get; set; }
        public string? UtmMedium { get; set; }
        public string? UtmCampaign { get; set; }

        public CampaignInput ToInput() => new(Name ?? string.Empty, Description, UtmSource, UtmMedium, UtmCampaign);

        public void Reset()
        {
            Name = Description = UtmSource = UtmMedium = UtmCampaign = null;
        }
    }

    sealed record CampaignRow(
        Guid Id, string Name, string? Description,
        string? UtmSource, string? UtmMedium, string? UtmCampaign, int LinkCount)
    {
        public bool HasUtm => !string.IsNullOrEmpty(UtmSource) || !string.IsNullOrEmpty(UtmMedium) || !string.IsNullOrEmpty(UtmCampaign);
    }
}
