@page "/users"
@attribute [Authorize(Policy = AdminClaims.SuperAdminPolicy)]
@inject IDbContextFactory<ShortLynxDbContext> DbFactory

<PageTitle>Users — ShortLynx Admin</PageTitle>
<h1 class="mb-4">Users</h1>

@if (!_loaded)
{
    <p class="text-muted">Loading…</p>
}
else if (_rows.Count == 0)
{
    <p class="text-muted">No users yet.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
            <tr>
                <th>Email</th>
                <th>Status</th>
                <th>Created</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var r in _rows)
            {
                <tr class="@(!r.IsActive ? "table-secondary text-muted" : null)">
                    <td>@r.Email</td>
                    <td>
                        @if (r.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td class="text-muted small text-nowrap">@r.CreatedAt.ToString("yyyy-MM-dd")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-outline-secondary" @onclick="PrevPage" disabled="@(_page == 1)">← Prev</button>
        <span class="align-self-center text-muted small">Page @_page</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="NextPage" disabled="@(_rows.Count < PageSize)">Next →</button>
    </div>
}

@code {
    const int PageSize = 50;
    int _page = 1;
    bool _loaded;
    List<UserRow> _rows = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    async Task LoadAsync()
    {
        _loaded = false;
        await using var db = await DbFactory.CreateDbContextAsync();
        var users = await db.UserAccountEntities
            .OrderByDescending(u => u.Id)
            .Skip((_page - 1) * PageSize)
            .Take(PageSize)
            .ToListAsync();

        _rows = users.Select(u => new UserRow(u.Email, u.IsActive, u.CreatedAt)).ToList();
        _loaded = true;
    }

    async Task PrevPage() { if (_page > 1) { _page--; await LoadAsync(); } }
    async Task NextPage() { _page++; await LoadAsync(); }

    sealed record UserRow(string Email, bool IsActive, DateTimeOffset CreatedAt);
}
