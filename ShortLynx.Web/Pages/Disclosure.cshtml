@page "/disclosure/{code}"
@model ShortLynx.Web.Pages.DisclosureModel
@{
    ViewData["Title"] = "Before you continue";
}

@* Served before a user-attributed redirect when the sender has no privacy policy configured.
   Deliberately static: no scripts, no analytics, no third-party resources — nothing is recorded
   unless and until the visitor chooses. *@

<div class="mx-auto max-w-lg px-4 py-12">
    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <h1 class="text-lg font-semibold mb-3">This link may be tracked</h1>

        <p class="text-sm text-gray-700 mb-2">
            This link was shared with you by <strong>@Model.OperatorName</strong> and leads to
            <strong>@Model.DestinationHost</strong>.
        </p>
        <p class="text-sm text-gray-700 mb-4">
            It was created just for you, so the sender may record that <em>you specifically</em>
            clicked it, along with your device type and general location. ShortLynx never stores
            your IP address or precise location —
            <a class="text-blue-700 hover:underline" href="/privacy">how we handle click data</a>.
        </p>

        <form method="post" class="flex flex-col gap-2">
            <input type="hidden" name="code" value="@Model.Code" />
            @Html.AntiForgeryToken()
            <button type="submit" name="choice" value="allow" data-testid="choice-allow"
                    class="w-full rounded bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">
                Continue
            </button>
            <button type="submit" name="choice" value="anon" data-testid="choice-anon"
                    class="w-full rounded border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                Continue without tracking
            </button>
            <button type="submit" name="choice" value="cancel" data-testid="choice-cancel"
                    class="w-full rounded px-4 py-2 text-sm text-gray-500 hover:bg-gray-50">
                No thanks — don't open this link
            </button>
        </form>

        <p class="text-xs text-gray-400 mt-4">
            Your choice is remembered for 30 days. Choosing "No thanks" records nothing and takes
            you to shrtlynx.com instead.
        </p>
    </div>
</div>
