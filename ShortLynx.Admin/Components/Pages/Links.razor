@page "/links"
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Options
@using ShortLynx.Services.Analytics
@using ShortLynx.Services.Entitlements
@using ShortLynx.Services.Links
@using ShortLynx.Services.ShortCodes
@inject IDbContextFactory<ShortLynxDbContext> DbFactory
@inject IServiceScopeFactory ScopeFactory
@inject IOptions<DashboardOptions> DashboardOpts
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Links — ShortLynx Admin</PageTitle>

<div class="flex justify-between items-center mb-3">
    <h1 class="text-2xl font-bold">Links</h1>
    @if (_canWrite)
    {
        <button class="btn btn-primary" @onclick="() => _showCreate = !_showCreate">
            @(_showCreate ? "Cancel" : "+ New link")
        </button>
    }
</div>

@if (_newShortCode is not null)
{
    <div class="alert alert-success mb-4" role="alert" data-testid="new-link">
        <div class="font-semibold mb-1">Link created.</div>
        <div class="flex gap-2 items-center">
            <a class="text-blue-700 hover:underline break-all font-mono" href="@_newShortUrl" target="_blank" rel="noopener" data-testid="new-link-url">@_newShortUrl</a>
            <button class="btn btn-outline-success" @onclick="CopyNewCode" data-testid="new-link-copy">Copy</button>
            <button type="button" class="ml-auto text-gray-400 hover:text-gray-600" aria-label="Dismiss" @onclick="DismissNew">✕</button>
        </div>
    </div>
}

@if (_showCreate)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Create a link</h5>
            <EditForm Model="_form" OnValidSubmit="CreateLink">
                <DataAnnotationsValidator/>
                <div class="mb-3">
                    <label class="field-label">Destination URL</label>
                    <InputText class="field-input" @bind-Value="_form.Url" placeholder="https://example.com/page"/>
                    <ValidationMessage For="() => _form.Url"/>
                    @if (_createError is not null)
                    {
                        <div class="text-red-600 text-sm mt-1" data-testid="create-error">@_createError</div>
                    }
                </div>
                <div class="mb-3">
                    <label class="field-label">Link type</label>
                    <InputRadioGroup @bind-Value="_form.Mode">
                        <div class="flex flex-col gap-1">
                            <label class="inline-flex items-center gap-2" for="mode-anon">
                                <InputRadio id="mode-anon" Value="LinkMode.Anonymous"/>
                                <span>Anonymous <span class="text-gray-500 text-sm">— one shared short code, aggregate clicks</span></span>
                            </label>
                            <label class="inline-flex items-center gap-2" for="mode-user">
                                <InputRadio id="mode-user" Value="LinkMode.UserAttributed"/>
                                <span>User-attributed <span class="text-gray-500 text-sm">— a code per recipient, per-recipient clicks</span></span>
                            </label>
                        </div>
                    </InputRadioGroup>
                </div>
                @if (_campaigns.Count > 0)
                {
                    <div class="mb-3">
                        <label class="field-label">Campaign <span class="text-gray-500 text-sm">(optional)</span></label>
                        <select class="field-input" @bind="_form.CampaignKey" data-testid="create-campaign">
                            <option value="">No campaign</option>
                            @foreach (var c in _campaigns)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                }
                @* Custom (vanity) code — Anonymous mode only. Paid on the hosted service; free self-host. *@
                @if (_form.Mode == LinkMode.Anonymous && _customCodesAvailable)
                {
                    <div class="mb-3">
                        <label class="field-label">Custom code <span class="text-gray-500 text-sm">(optional, 8–12 chars)</span></label>
                        <input class="field-input" @bind="_customCode" @bind:event="oninput" @bind:after="OnCustomCodeChanged"
                               placeholder="my-link-2025" data-testid="custom-code"/>
                        @if (!string.IsNullOrEmpty(_customCode))
                        {
                            <div class="text-sm mt-1" data-testid="custom-code-status">
                                @if (_customCodeChecking) { <span class="text-gray-500">Checking…</span> }
                                else if (_customCodeAvailable == true) { <span class="text-green-600">✓ Available</span> }
                                else if (_customCodeReason is not null) { <span class="text-red-600">@_customCodeReason</span> }
                            </div>
                        }
                    </div>
                }
                else if (_form.Mode == LinkMode.Anonymous && _customCodesGateKnown)
                {
                    <div class="mb-3 text-sm text-gray-500" data-testid="custom-code-upsell">
                        Choosing your own code is a paid feature — upgrade your plan to enable custom codes.
                    </div>
                }
                <button type="submit" class="btn btn-primary" data-testid="create-submit">
                    @(_form.Mode == LinkMode.UserAttributed ? "Create & add recipients" : "Create link")
                </button>
            </EditForm>
        </div>
    </div>
}

@if (!_loaded)
{
    <p class="text-gray-500">Loading…</p>
}
else if (_rows.Count == 0)
{
    <p class="text-gray-500">No links yet.</p>
}
else
{
    <div class="overflow-x-auto">
        <table class="data-table">
            <thead>
            <tr>
                <th>Code</th>
                <th>URL</th>
                <th>Owner</th>
                <th>Mode</th>
                <th class="text-right">Clicks</th>
                <th>Created</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var r in _rows)
            {
                <tr>
                    <td><code>@r.ShortCode</code></td>
                    <td class="truncate max-w-[280px]" title="@r.Url">@r.Url</td>
                    <td class="text-gray-500 text-sm">@r.ApiKeyName</td>
                    <td><span class="badge @(r.Mode == "Anonymous" ? "badge-gray" : "badge-blue")">@r.Mode</span></td>
                    <td class="text-right">@r.Clicks</td>
                    <td class="text-gray-500 text-sm whitespace-nowrap">@r.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td><a class="btn btn-outline-primary" href="/links/@r.Id">View</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="flex gap-2 mt-3">
        <button class="btn btn-outline" @onclick="PrevPage" disabled="@(_page == 1)">← Prev</button>
        <span class="self-center text-gray-500 text-sm">Page @_page</span>
        <button class="btn btn-outline" @onclick="NextPage" disabled="@(_rows.Count < PageSize)">Next →</button>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    const int PageSize = 20;
    int _page = 1;
    bool _loaded;
    bool _resolved;
    Guid _uid;
    Guid _accountId;
    List<LinkRow> _rows = [];
    List<CampaignOption> _campaigns = [];

    bool _canWrite;

    protected override async Task OnInitializedAsync()
    {
        var principal = (await AuthState).User;
        await using (var db = await DbFactory.CreateDbContextAsync())
        {
            var ctx = await AccountRoleContext.ResolveAsync(db, principal);
            if (ctx is null) { _loaded = true; return; }
            (_uid, _accountId, _canWrite) = (ctx.UserId, ctx.AccountId, ctx.CanManageResources);
            _campaigns = await db.CampaignEntities
                .Where(c => c.AccountId == _accountId)
                .OrderBy(c => c.Name)
                .Select(c => new CampaignOption(c.Id, c.Name))
                .ToListAsync();
        }

        // Custom codes: only relevant to users who can create links. Self-host is always allowed
        // (UnlimitedEntitlements); hosted depends on plan.
        if (_canWrite)
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var ent = scope.ServiceProvider.GetRequiredService<IEntitlements>();
            _customCodesAvailable = await ent.CanCreateCustomCodeAsync(_accountId);
            _customCodesGateKnown = true;
        }

        _resolved = true;
        await LoadAsync();
    }

    async Task LoadAsync()
    {
        if (!_resolved) return;
        _loaded = false;
        await using var db = await DbFactory.CreateDbContextAsync();

        var links = await db.LinkEntities
            .Include(l => l.ApiKey)
            .Where(l => l.AccountId == _accountId)
            .OrderByDescending(l => l.Id)
            .Skip((_page - 1) * PageSize)
            .Take(PageSize)
            .ToListAsync();

        var linkIds = links.Select(l => l.Id).ToList();

        // Shared codes only supply the displayed code for anonymous links; the click *count* comes from
        // LinkVisitQueries so user-attributed links (whose clicks live in UserVisits) aren't shown as 0.
        var codeMap = (await db.ShortCodeEntities
                .Where(sc => linkIds.Contains(sc.LinkId))
                .Select(sc => new { sc.LinkId, sc.Code })
                .ToListAsync())
            .ToDictionary(sc => sc.LinkId, sc => sc.Code);
        var clickMap = await LinkVisitQueries.CountByLinkAsync(db, linkIds);

        _rows = links.Select(l =>
            new LinkRow(l.Id, l.OriginalUrl, l.Mode.ToString(),
                codeMap.GetValueOrDefault(l.Id, string.Empty), l.ApiKey?.Name ?? "Dashboard",
                l.CreatedAt, (int)clickMap.GetValueOrDefault(l.Id, 0))).ToList();

        _loaded = true;
    }

    async Task PrevPage() { if (_page > 1) { _page--; await LoadAsync(); } }
    async Task NextPage() { _page++; await LoadAsync(); }

    bool _showCreate;
    string? _newShortCode;
    string? _newShortUrl;
    string? _createError;
    CreateLinkForm _form = new();

    // Custom (vanity) code state.
    bool _customCodesAvailable;      // account may mint custom codes (self-host: always; hosted: per plan)
    bool _customCodesGateKnown;      // entitlement resolved (avoids flashing the upsell before load)
    string? _customCode;
    bool _customCodeChecking;
    bool? _customCodeAvailable;
    string? _customCodeReason;
    CancellationTokenSource? _customCodeDebounce;

    // Debounced availability check: reset the timer each keystroke, then check ~350ms after typing stops.
    async Task OnCustomCodeChanged()
    {
        _customCodeAvailable = null;
        _customCodeReason = null;
        _customCodeDebounce?.Cancel();

        if (string.IsNullOrWhiteSpace(_customCode))
        {
            _customCodeChecking = false;
            return;
        }

        _customCodeChecking = true;
        var cts = new CancellationTokenSource();
        _customCodeDebounce = cts;
        try
        {
            await Task.Delay(350, cts.Token);
            await using var scope = ScopeFactory.CreateAsyncScope();
            var svc = scope.ServiceProvider.GetRequiredService<ICustomCodeService>();
            var result = await svc.CheckAsync(_customCode, cts.Token);
            if (cts.IsCancellationRequested) return;

            _customCodeChecking = false;
            _customCodeAvailable = result.IsAvailable;
            _customCodeReason = result.IsAvailable ? null : result.Reason;
            StateHasChanged();
        }
        catch (TaskCanceledException)
        {
            // Superseded by a newer keystroke — the newer call owns the state.
        }
    }

    async Task CreateLink()
    {
        // Handler-level guard, not just hidden UI — Blazor Server executes handlers regardless of markup.
        if (!_resolved || !_canWrite) return;
        _createError = null;
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var svc = scope.ServiceProvider.GetRequiredService<ILinkService>();

            if (_form.Mode == LinkMode.UserAttributed)
            {
                // Mode-2 links have no shared code — go straight to the detail page to add recipients.
                var link = await svc.CreateUserAttributedLinkAsync(_form.Url!, _accountId, _uid, _form.CampaignId);
                _form = new();
                _showCreate = false;
                Nav.NavigateTo($"/links/{link.Id}");
                return;
            }

            var custom = _customCodesAvailable && !string.IsNullOrWhiteSpace(_customCode) ? _customCode : null;
            var result = await svc.CreateAnonymousLinkAsync(_form.Url!, _accountId, _uid, _form.CampaignId, custom);
            _newShortCode = result.ShortCode.Code;
            _newShortUrl = DashboardOpts.Value.BuildShortUrl(result.ShortCode.Code);
            _form = new();
            ResetCustomCode();
            _showCreate = false;
            await LoadAsync();
        }
        catch (CustomCodeTakenException)
        {
            _createError = "That custom code was just taken — try another.";
            _customCodeAvailable = false;
        }
        catch (ArgumentException ex)
        {
            // URL validation / SSRF rejection, or an invalid custom code.
            _createError = ex.Message;
        }
        catch (ShortLynx.Services.Entitlements.EntitlementException ex)
        {
            // Plan limit / feature not in tier (never thrown under the OSS UnlimitedEntitlements default).
            _createError = ex.Message;
        }
    }

    void ResetCustomCode()
    {
        _customCode = null;
        _customCodeAvailable = null;
        _customCodeReason = null;
        _customCodeChecking = false;
    }

    async Task CopyNewCode()
    {
        if (_newShortUrl is not null)
            await JS.InvokeVoidAsync("shortlynxCopy", _newShortUrl);
    }

    void DismissNew()
    {
        _newShortCode = null;
        _newShortUrl = null;
    }

    sealed record LinkRow(Guid Id, string Url, string Mode, string ShortCode,
        string ApiKeyName, DateTimeOffset CreatedAt, int Clicks);

    sealed class CreateLinkForm
    {
        [Required(ErrorMessage = "URL is required."), Url(ErrorMessage = "Enter a valid URL.")]
        public string? Url { get; set; }

        public LinkMode Mode { get; set; } = LinkMode.Anonymous;

        // Empty string = "No campaign"; a Guid string = the chosen campaign.
        public string CampaignKey { get; set; } = string.Empty;

        public Guid? CampaignId => Guid.TryParse(CampaignKey, out var id) ? id : null;
    }

    sealed record CampaignOption(Guid Id, string Name);
}
