@page "/links"
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.DependencyInjection
@using ShortLynx.Services.Links
@inject IDbContextFactory<ShortLynxDbContext> DbFactory
@inject IServiceScopeFactory ScopeFactory
@inject IJSRuntime JS

<PageTitle>Links — ShortLynx Admin</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Links</h1>
    <button class="btn btn-primary btn-sm" @onclick="() => _showCreate = !_showCreate">
        @(_showCreate ? "Cancel" : "+ New link")
    </button>
</div>

@if (_newShortCode is not null)
{
    <div class="alert alert-success" role="alert" data-testid="new-link">
        <div class="fw-semibold mb-1">Link created.</div>
        <div class="d-flex gap-2 align-items-center">
            <span>Short code: <code>@_newShortCode</code></span>
            <button class="btn btn-sm btn-outline-success" @onclick="CopyNewCode">Copy</button>
            <button type="button" class="btn-close ms-auto" aria-label="Dismiss" @onclick="() => _newShortCode = null"></button>
        </div>
    </div>
}

@if (_showCreate)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title">Create a link</h5>
            <EditForm Model="_form" OnValidSubmit="CreateLink">
                <DataAnnotationsValidator/>
                <div class="mb-3">
                    <label class="form-label">Destination URL</label>
                    <InputText class="form-control" @bind-Value="_form.Url" placeholder="https://example.com/page"/>
                    <ValidationMessage For="() => _form.Url"/>
                    @if (_createError is not null)
                    {
                        <div class="text-danger small mt-1" data-testid="create-error">@_createError</div>
                    }
                </div>
                <button type="submit" class="btn btn-primary btn-sm">Create link</button>
            </EditForm>
        </div>
    </div>
}

@if (!_loaded)
{
    <p class="text-muted">Loading…</p>
}
else if (_rows.Count == 0)
{
    <p class="text-muted">No links yet.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
            <tr>
                <th>Code</th>
                <th>URL</th>
                <th>Owner</th>
                <th>Mode</th>
                <th class="text-end">Clicks</th>
                <th>Created</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var r in _rows)
            {
                <tr>
                    <td><code>@r.ShortCode</code></td>
                    <td class="text-truncate" style="max-width:280px" title="@r.Url">@r.Url</td>
                    <td class="text-muted small">@r.ApiKeyName</td>
                    <td><span class="badge @(r.Mode == "Anonymous" ? "bg-secondary" : "bg-primary")">@r.Mode</span></td>
                    <td class="text-end">@r.Clicks</td>
                    <td class="text-muted small text-nowrap">@r.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td><a class="btn btn-sm btn-outline-primary" href="/links/@r.Id">View</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-outline-secondary" @onclick="PrevPage" disabled="@(_page == 1)">← Prev</button>
        <span class="align-self-center text-muted small">Page @_page</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="NextPage" disabled="@(_rows.Count < PageSize)">Next →</button>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    const int PageSize = 20;
    int _page = 1;
    bool _loaded;
    bool _resolved;
    Guid _uid;
    List<LinkRow> _rows = [];

    protected override async Task OnInitializedAsync()
    {
        var userId = (await AuthState).User.GetUserId();
        if (userId is null) { _loaded = true; return; }
        _uid = userId.Value;
        _resolved = true;
        await LoadAsync();
    }

    async Task LoadAsync()
    {
        if (!_resolved) return;
        _loaded = false;
        await using var db = await DbFactory.CreateDbContextAsync();

        var links = await db.LinkEntities
            .Include(l => l.ApiKey)
            .Where(l => l.UserAccountId == _uid || l.ApiKey!.UserAccountId == _uid)
            .OrderByDescending(l => l.Id)
            .Skip((_page - 1) * PageSize)
            .Take(PageSize)
            .ToListAsync();

        var linkIds = links.Select(l => l.Id).ToList();

        var codes = await db.ShortCodeEntities
            .Where(sc => linkIds.Contains(sc.LinkId))
            .ToListAsync();

        var codeMap = codes.ToDictionary(sc => sc.LinkId, sc => sc);
        var codeIds = codes.Select(sc => sc.Id).ToList();

        var visits = await db.VisitEntities
            .Where(v => codeIds.Contains(v.ShortCodeId))
            .GroupBy(v => v.ShortCodeId)
            .Select(g => new { Id = g.Key, Count = g.Count() })
            .ToListAsync();

        var clickMap = visits.ToDictionary(v => v.Id, v => v.Count);

        _rows = links.Select(l =>
        {
            var sc = codeMap.GetValueOrDefault(l.Id);
            var clicks = sc is not null ? clickMap.GetValueOrDefault(sc.Id, 0) : 0;
            return new LinkRow(l.Id, l.OriginalUrl, l.Mode.ToString(),
                sc?.Code ?? string.Empty, l.ApiKey?.Name ?? "Dashboard",
                l.CreatedAt, clicks);
        }).ToList();

        _loaded = true;
    }

    async Task PrevPage() { if (_page > 1) { _page--; await LoadAsync(); } }
    async Task NextPage() { _page++; await LoadAsync(); }

    bool _showCreate;
    string? _newShortCode;
    string? _createError;
    CreateLinkForm _form = new();

    async Task CreateLink()
    {
        if (!_resolved) return;
        _createError = null;
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var svc = scope.ServiceProvider.GetRequiredService<ILinkService>();
            var result = await svc.CreateAnonymousLinkAsync(_form.Url!, _uid);
            _newShortCode = result.ShortCode.Code;
            _form = new();
            _showCreate = false;
            await LoadAsync();
        }
        catch (ArgumentException ex)
        {
            // URL validation / SSRF rejection.
            _createError = ex.Message;
        }
    }

    async Task CopyNewCode()
    {
        if (_newShortCode is not null)
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _newShortCode);
    }

    sealed record LinkRow(Guid Id, string Url, string Mode, string ShortCode,
        string ApiKeyName, DateTimeOffset CreatedAt, int Clicks);

    sealed class CreateLinkForm
    {
        [Required(ErrorMessage = "URL is required."), Url(ErrorMessage = "Enter a valid URL.")]
        public string? Url { get; set; }
    }
}
