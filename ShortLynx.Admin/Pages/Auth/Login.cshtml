@page
@model ShortLynx.Admin.Pages.Auth.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — ShortLynx Admin</title>
    <link rel="stylesheet" href="~/css/tailwind.css" />
    <link rel="stylesheet" href="~/app.css" />
</head>
<body class="bg-gray-50 flex items-center min-h-screen">
<div class="mx-auto w-full max-w-sm px-4">
    <div class="card">
        <div class="card-body p-6">
            <h4 class="text-lg font-bold text-center mb-1">ShortLynx Admin</h4>
            <p class="text-center text-gray-500 text-sm mb-4">Enter your email to receive a sign-in link.</p>

            @if (Model.Sent)
            {
                <div class="alert alert-success mb-3">
                    Check your email for a sign-in link. It expires in 15&nbsp;minutes.
                </div>
            }

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-2"></div>
                <div class="mb-3">
                    <label asp-for="Email" class="field-label">Email address</label>
                    <input asp-for="Email" class="field-input" type="email"
                           placeholder="you@example.com" autofocus autocomplete="email" />
                    <span asp-validation-for="Email" class="text-red-600 text-sm"></span>
                </div>
                <button type="submit" class="btn btn-primary w-full">Send sign-in link</button>
            </form>
        </div>
    </div>
</div>
</body>
</html>
