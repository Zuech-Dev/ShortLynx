@page
@model ShortLynx.Admin.Pages.Auth.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — ShortLynx Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light d-flex align-items-center" style="min-height:100vh">
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h4 class="card-title text-center fw-bold mb-1">ShortLynx Admin</h4>
                    <p class="text-center text-muted small mb-4">Enter your email to receive a sign-in link.</p>

                    @if (Model.Sent)
                    {
                        <div class="alert alert-success py-2">
                            Check your email for a sign-in link. It expires in 15&nbsp;minutes.
                        </div>
                    }

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email address</label>
                            <input asp-for="Email" class="form-control" type="email"
                                   placeholder="you@example.com" autofocus autocomplete="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Send sign-in link</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>
