@page
@model ShortLynx.Admin.Pages.Auth.ConfirmModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — ShortLynx Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light d-flex align-items-center" style="min-height:100vh">
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <h4 class="card-title fw-bold mb-3">ShortLynx Admin</h4>
                    <div class="alert alert-danger">
                        <strong>Invalid or expired link.</strong>
                        <p class="mb-0 small mt-1">@Model.Error</p>
                    </div>
                    <a href="/auth/login" class="btn btn-outline-primary mt-2">Request a new link</a>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>
