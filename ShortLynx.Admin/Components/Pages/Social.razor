@page "/social"
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.DependencyInjection
@using ShortLynx.Services.Entitlements
@using ShortLynx.Services.Social
@inject IServiceScopeFactory ScopeFactory
@inject IDbContextFactory<ShortLynxDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Social Accounts — ShortLynx Admin</PageTitle>

<div class="flex justify-between items-center mb-3">
    <h1 class="text-2xl font-bold">Social Accounts</h1>
    @if (_canWrite)
    {
        <div class="flex gap-2">
            <a class="btn btn-outline" href="/social/threads/authorize" data-testid="connect-threads">Connect Threads</a>
            <a class="btn btn-outline" href="/social/reddit/authorize" data-testid="connect-reddit">Connect Reddit</a>
            <button class="btn btn-primary" data-testid="connect-toggle" @onclick="() => _showConnect = !_showConnect">
                @(_showConnect ? "Cancel" : "+ Connect account")
            </button>
        </div>
    }
</div>

<p class="text-gray-500 text-sm mb-3 max-w-[640px]">
    Connect Bluesky, Mastodon, or Threads accounts to publish tracked links directly and pull post
    engagement. Credentials/authorization are verified with the platform and tokens are stored
    encrypted — they are never shown again.
</p>

@if (_oauthConnected is not null)
{
    <div class="text-green-600 text-sm mb-3" data-testid="threads-connected">@_oauthConnected account connected.</div>
}
@if (_oauthError is not null)
{
    <div class="text-red-600 text-sm mb-3" data-testid="threads-error">Couldn't connect @_oauthErrorPlatform: @_oauthError</div>
}

@if (_showConnect)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Connect an account</h5>
            <EditForm Model="_form" OnValidSubmit="Connect">
                <DataAnnotationsValidator/>
                <div class="mb-3">
                    <label class="field-label">Platform</label>
                    <InputSelect class="field-input max-w-[240px]" @bind-Value="_form.Platform" data-testid="connect-platform">
                        <option value="Bluesky">Bluesky</option>
                        <option value="Mastodon">Mastodon</option>
                    </InputSelect>
                </div>
                @if (_form.Platform == "Mastodon")
                {
                    <div class="mb-3">
                        <label class="field-label">Instance URL</label>
                        <InputText class="field-input" @bind-Value="_form.InstanceUrl"
                                   placeholder="https://mastodon.social" data-testid="connect-instance"/>
                        <div class="text-gray-500 text-sm mt-1">Your Mastodon server.</div>
                    </div>
                    <div class="mb-3">
                        <label class="field-label">Access token</label>
                        <InputText type="password" class="field-input" @bind-Value="_form.Secret" data-testid="connect-secret"/>
                        <div class="text-gray-500 text-sm mt-1">
                            Create one on your instance under <em>Settings → Development → New application</em>
                            (scopes: read, write).
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="field-label">Handle <span class="text-gray-500 text-sm">(for your reference)</span></label>
                        <InputText class="field-input" @bind-Value="_form.Identifier" placeholder="@("@you@mastodon.social")" data-testid="connect-identifier"/>
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <label class="field-label">Handle</label>
                        <InputText class="field-input" @bind-Value="_form.Identifier"
                                   placeholder="you.bsky.social" data-testid="connect-identifier"/>
                    </div>
                    <div class="mb-3">
                        <label class="field-label">App password</label>
                        <InputText type="password" class="field-input" @bind-Value="_form.Secret" data-testid="connect-secret"/>
                        <div class="text-gray-500 text-sm mt-1">
                            Create one in Bluesky under <em>Settings → App Passwords</em> — never your main password.
                        </div>
                    </div>
                }
                @if (_connectError is not null)
                {
                    <div class="text-red-600 text-sm mb-2" data-testid="connect-error">@_connectError</div>
                }
                <button type="submit" class="btn btn-primary" disabled="@_busy" data-testid="connect-submit">
                    @(_busy ? "Verifying…" : "Connect")
                </button>
            </EditForm>
        </div>
    </div>
}

@if (!_loaded)
{
    <p class="text-gray-500">Loading…</p>
}
else if (_connections.Count == 0)
{
    <p class="text-gray-500" data-testid="social-empty">No social accounts connected yet.</p>
}
else
{
    <div class="flex flex-col gap-3">
        @foreach (var c in _connections)
        {
            <div class="card" data-testid="social-row">
                <div class="card-body">
                    <div class="flex items-center gap-2">
                        <span class="badge @BadgeClass(c.Platform)">@c.Platform</span>
                        <span class="font-semibold">@c.Handle</span>
                        @if (!string.IsNullOrEmpty(c.InstanceUrl))
                        {
                            <span class="text-gray-500 text-sm">@c.InstanceUrl</span>
                        }
                        <span class="text-gray-500 text-sm ml-auto">connected @c.CreatedAt.ToString("yyyy-MM-dd")</span>
                        @if (_canWrite)
                        {
                            <button class="btn btn-outline-danger" disabled="@_busy" data-testid="disconnect-btn"
                                    @onclick="() => Disconnect(c.Id)">Disconnect</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    bool _loaded, _resolved, _showConnect, _busy, _canWrite;
    string? _oauthConnected, _oauthError, _oauthErrorPlatform;
    Guid _uid, _accountId;
    List<ConnectionRow> _connections = [];
    readonly ConnectForm _form = new();
    string? _connectError;

    protected override async Task OnInitializedAsync()
    {
        var principal = (await AuthState).User;
        await using (var db = await DbFactory.CreateDbContextAsync())
        {
            var ctx = await AccountRoleContext.ResolveAsync(db, principal);
            if (ctx is null) { _loaded = true; return; }
            (_uid, _accountId, _canWrite) = (ctx.UserId, ctx.AccountId, ctx.CanManageResources);
        }
        _resolved = true;

        // Surfaces the result of a redirect back from an OAuth callback (/social/{slug}/callback).
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("connected", out var connected))
            _oauthConnected = PlatformDisplayName((string?)connected);
        foreach (var slug in new[] { "threads", "reddit" })
        {
            if (!query.TryGetValue($"{slug}Error", out var err)) continue;
            _oauthErrorPlatform = PlatformDisplayName(slug);
            _oauthError = FriendlyOAuthError(err!, slug);
        }

        await LoadAsync();
    }

    static string BadgeClass(string platform) => platform switch
    {
        "Bluesky" => "badge-blue",
        "Threads" => "badge-yellow",
        "Reddit" => "badge-orange",
        _ => "badge-gray", // Mastodon
    };

    static string? PlatformDisplayName(string? slug) => slug switch
    {
        "threads" => "Threads",
        "reddit" => "Reddit",
        _ => null,
    };

    // The callback/authorize endpoints pass short error codes; platform ArgumentException messages pass
    // through as-is (they're already human-readable).
    static string FriendlyOAuthError(string code, string slug)
    {
        var configSection = slug == "reddit" ? "Reddit" : "Threads";
        var setupDoc = slug == "reddit" ? "docs/REDDIT_APP_SETUP.md" : "docs/META_APP_SETUP.md";
        return code switch
        {
            "not_configured" => $"{configSection} isn't configured on this server yet — the operator needs to set {configSection}:AppId and {configSection}:AppSecret (see {setupDoc}).",
            "missing_state" or "invalid_state" or "state_mismatch" => "The sign-in attempt couldn't be verified (state check failed). Try connecting again.",
            "missing_code" => "The platform didn't return an authorization code. Try connecting again.",
            "plan" => "Social publishing is not available on your plan.",
            _ => code,
        };
    }

    async Task LoadAsync()
    {
        if (!_resolved) return;
        await using var scope = ScopeFactory.CreateAsyncScope();
        var svc = scope.ServiceProvider.GetRequiredService<ISocialConnectionService>();
        var list = await svc.ListAsync(_accountId);
        _connections = list.Select(c => new ConnectionRow(
            c.Id, c.Platform.ToString(), c.Handle, c.InstanceUrl, c.CreatedAt)).ToList();
        _loaded = true;
    }

    async Task Connect()
    {
        // Handler-level guard, not just hidden UI — Blazor Server executes handlers regardless of markup.
        if (!_resolved || !_canWrite) return;
        _connectError = null;

        if (!Enum.TryParse<SocialPlatform>(_form.Platform, ignoreCase: true, out var platform))
        {
            _connectError = $"Unknown platform '{_form.Platform}'.";
            return;
        }

        _busy = true;
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var svc = scope.ServiceProvider.GetRequiredService<ISocialConnectionService>();
            await svc.ConnectAsync(_accountId, _uid, platform,
                new SocialCredentials(_form.Identifier ?? string.Empty, _form.Secret!, _form.InstanceUrl));
            _form.Reset();
            _showConnect = false;
            await LoadAsync();
        }
        catch (ArgumentException ex) { _connectError = ex.Message; }
        catch (EntitlementException ex) { _connectError = ex.Message; }
        catch (HttpRequestException) { _connectError = "The platform could not be reached. Try again shortly."; }
        finally { _busy = false; }
    }

    async Task Disconnect(Guid id)
    {
        if (!_canWrite) return;
        _busy = true;
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var svc = scope.ServiceProvider.GetRequiredService<ISocialConnectionService>();
            await svc.DisconnectAsync(id, _accountId);
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    sealed class ConnectForm
    {
        public string Platform { get; set; } = "Bluesky";
        public string? Identifier { get; set; }

        [Required(ErrorMessage = "The app password / access token is required.")]
        public string? Secret { get; set; }

        public string? InstanceUrl { get; set; }

        public void Reset()
        {
            Identifier = Secret = InstanceUrl = null;
            Platform = "Bluesky";
        }
    }

    sealed record ConnectionRow(Guid Id, string Platform, string Handle, string? InstanceUrl, DateTimeOffset CreatedAt);
}
