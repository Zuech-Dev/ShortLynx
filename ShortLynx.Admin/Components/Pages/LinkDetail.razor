@page "/links/{Id:guid}"
@attribute [Authorize]
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Options
@using ShortLynx.Services.Analytics
@using ShortLynx.Services.Campaigns
@using ShortLynx.Services.Links
@using ShortLynx.Services.Social
@inject IDbContextFactory<ShortLynxDbContext> DbFactory
@inject IServiceScopeFactory ScopeFactory
@inject IOptions<DashboardOptions> DashboardOpts
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Link Detail — ShortLynx Admin</PageTitle>

@if (_notFound)
{
    <p class="text-red-600">Link not found.</p>
    <a href="/links" class="btn btn-outline">← Back to Links</a>
}
else if (!_loaded)
{
    <p class="text-gray-500">Loading…</p>
}
else
{
    <div class="flex items-center gap-2 mb-3">
        <a href="/links" class="btn btn-outline">← Back</a>
        <h1 class="text-xl font-bold">Link Detail</h1>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <dl class="grid grid-cols-1 sm:grid-cols-[8rem_1fr] gap-x-4 gap-y-2 mb-0">
                <dt class="font-medium text-gray-500">URL</dt>
                <dd><a class="text-blue-700 hover:underline" href="@_link!.OriginalUrl" target="_blank" rel="noopener">@_link.OriginalUrl</a></dd>

                <dt class="font-medium text-gray-500">Short URL</dt>
                <dd>
                    @if (!string.IsNullOrEmpty(_shortUrl))
                    {
                        <span class="inline-flex items-center gap-2 flex-wrap">
                            <a class="text-blue-700 hover:underline break-all" href="@_shortUrl" target="_blank" rel="noopener" data-testid="short-url">@_shortUrl</a>
                            <button class="btn btn-outline-success" @onclick="CopyShortUrl" data-testid="copy-short-url">Copy</button>
                            @if (_shortUrlCopied)
                            {
                                <span class="text-green-600 text-sm" data-testid="short-url-copied">Copied.</span>
                            }
                        </span>
                    }
                    else
                    {
                        <span class="text-gray-500">— <span class="text-sm">(per-recipient codes below)</span></span>
                    }
                </dd>

                <dt class="font-medium text-gray-500">Mode</dt>
                <dd>@_link.Mode</dd>

                <dt class="font-medium text-gray-500">API Key</dt>
                <dd>@(_link.ApiKey?.Name ?? "—")</dd>

                <dt class="font-medium text-gray-500">Created</dt>
                <dd>@_link.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</dd>
            </dl>
        </div>
    </div>

    @if (_link.Mode == LinkMode.Anonymous && !string.IsNullOrEmpty(_shortCode))
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">QR code</h5>
                <p class="text-gray-500 text-sm">Download a QR code that opens this short link — PNG for embedding or print, SVG for scalable use.</p>
                <div class="flex items-center gap-4">
                    <img src="/qr/@Id?format=svg" alt="QR code for this link" width="140" height="140"
                         class="border border-gray-200 rounded" data-testid="qr-preview"/>
                    <div class="flex flex-col gap-2">
                        <a class="btn btn-primary" href="/qr/@Id?format=png" download data-testid="qr-png">Download PNG</a>
                        <a class="btn btn-outline" href="/qr/@Id?format=svg" download data-testid="qr-svg">Download SVG</a>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_canPin)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Custom domain</h5>
                <p class="text-gray-500 text-sm">Pin this link to one of your verified domains, or leave it on any host.</p>
                <div class="flex gap-2 items-center max-w-[520px]">
                    <select class="field-input" @bind="_selectedDomainKey" data-testid="pin-select">
                        <option value="">Any host (no pin)</option>
                        @foreach (var d in _verifiedDomains)
                        {
                            <option value="@d.Id">@d.Domain</option>
                        }
                    </select>
                    <button class="btn btn-primary" data-testid="pin-save" @onclick="SavePin">Save</button>
                </div>
                @if (_verifiedDomains.Count == 0)
                {
                    <div class="text-sm text-gray-500 mt-1">No verified domains yet — add one under <a class="text-blue-700 hover:underline" href="/domains">Domains</a>.</div>
                }
                @if (_pinSaved)
                {
                    <div class="text-green-600 text-sm mt-1" data-testid="pin-saved">Saved.</div>
                }
            </div>
        </div>
    }

    @if (_canPin)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Campaign</h5>
                <p class="text-gray-500 text-sm">Group this link under a campaign for roll-up analytics and a shared UTM template.</p>
                <div class="flex gap-2 items-center max-w-[520px]">
                    <select class="field-input" @bind="_selectedCampaignKey" data-testid="campaign-select">
                        <option value="">No campaign</option>
                        @foreach (var c in _campaignOptions)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                    <button class="btn btn-primary" data-testid="campaign-save" @onclick="SaveCampaign">Save</button>
                </div>
                @if (_campaignOptions.Count == 0)
                {
                    <div class="text-sm text-gray-500 mt-1">No campaigns yet — create one under <a class="text-blue-700 hover:underline" href="/campaigns">Campaigns</a>.</div>
                }
                @if (_campaignSaved)
                {
                    <div class="text-green-600 text-sm mt-1" data-testid="campaign-saved">Saved.</div>
                }
            </div>
        </div>
    }

    @if (_canPin && _link.Mode == LinkMode.Anonymous && !string.IsNullOrEmpty(_shortUrl))
    {
        <div class="card mb-4" data-testid="publish-card">
            <div class="card-body">
                <h5 class="card-title">Post to social</h5>
                @if (_socialConnections.Count == 0)
                {
                    <p class="text-gray-500 text-sm">No social accounts connected yet — connect one under
                        <a class="text-blue-700 hover:underline" href="/social">Social</a> to publish this link.</p>
                }
                else
                {
                    <p class="text-gray-500 text-sm">The short URL is appended to your message automatically.</p>
                    <div class="mb-2">
                        <textarea class="field-input" rows="3" @bind="_publishText"
                                  placeholder="Say something about this link…" data-testid="publish-text"></textarea>
                    </div>
                    <div class="flex flex-col gap-1 mb-3">
                        @foreach (var c in _socialConnections)
                        {
                            <label class="inline-flex items-center gap-2">
                                <input type="checkbox" checked="@_publishTargets.Contains(c.Id)"
                                       @onchange="e => ToggleTarget(c.Id, e.Value is true)" data-testid="publish-target"/>
                                <span class="badge @(c.Platform == "Bluesky" ? "badge-blue" : "badge-gray")">@c.Platform</span>
                                <span>@c.Handle</span>
                            </label>
                        }
                    </div>
                    <button class="btn btn-primary" disabled="@(_busyPublishing || _publishTargets.Count == 0)"
                            @onclick="PublishAsync" data-testid="publish-submit">
                        @(_busyPublishing ? "Posting…" : "Post")
                    </button>

                    @if (_publishResults.Count > 0)
                    {
                        <ul class="mt-3 space-y-1 text-sm" data-testid="publish-results">
                            @foreach (var r in _publishResults)
                            {
                                <li>
                                    @if (r.Success)
                                    {
                                        <span class="text-green-600">✓ @r.Handle</span>
                                        @if (r.PostUrl is not null)
                                        {
                                            <text> — </text><a class="text-blue-700 hover:underline" href="@r.PostUrl" target="_blank" rel="noopener">view post</a>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-red-600">✗ @r.Handle — @r.Error</span>
                                    }
                                </li>
                            }
                        </ul>
                    }
                }

                @if (_posts.Count > 0)
                {
                    <div class="flex items-center mt-4 mb-2">
                        <h6 class="font-semibold text-sm">Published posts</h6>
                        <button class="btn btn-outline ml-auto" disabled="@_busyMetrics"
                                @onclick="RefreshMetricsAsync" data-testid="refresh-metrics">
                            @(_busyMetrics ? "Refreshing…" : "Refresh metrics")
                        </button>
                    </div>
                    <p class="text-gray-500 text-xs mb-2">
                        Likes/reposts/replies come from the platform. Bluesky and Mastodon don't report
                        impressions, so click-through rate needs the gated platforms (later phase).
                        Metrics also refresh automatically in the background.
                    </p>
                    <table class="data-table" data-testid="social-posts">
                        <thead>
                        <tr><th>Platform</th><th>Account</th><th>Posted</th>
                            <th class="text-right">Likes</th><th class="text-right">Reposts</th>
                            <th class="text-right">Replies</th><th class="text-right">Impressions</th><th></th></tr>
                        </thead>
                        <tbody>
                        @foreach (var p in _posts)
                        {
                            <tr>
                                <td>@p.Platform</td>
                                <td>@p.Handle</td>
                                <td class="whitespace-nowrap">@p.PostedAt.ToString("yyyy-MM-dd HH:mm") UTC</td>
                                <td class="text-right">@(p.Likes?.ToString() ?? "—")</td>
                                <td class="text-right">@(p.Reposts?.ToString() ?? "—")</td>
                                <td class="text-right">@(p.Replies?.ToString() ?? "—")</td>
                                <td class="text-right">@(p.Impressions?.ToString() ?? "—")</td>
                                <td>
                                    @if (p.PostUrl is not null)
                                    {
                                        <a class="text-blue-700 hover:underline text-sm" href="@p.PostUrl" target="_blank" rel="noopener">view</a>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }

    <ClickBreakdownCard Breakdown="_breakdown" />

    @if (_link.Mode == LinkMode.UserAttributed)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Provision codes</h5>
                <p class="text-gray-500 text-sm">One recipient per line (e.g. an email or campaign tag). A unique short code is minted for each.</p>
                <EditForm Model="_provision" OnValidSubmit="ProvisionCodes">
                    <div class="mb-2">
                        <InputTextArea class="field-input font-mono" rows="4" @bind-Value="_provision.Recipients"
                                       placeholder="alice@example.com&#10;bob@example.com" data-testid="provision-input"/>
                    </div>
                    <label class="inline-flex items-center gap-2 mb-2" for="one-time">
                        <InputCheckbox id="one-time" @bind-Value="_provision.IsOneTimeUse"/>
                        <span>One-time use <span class="text-gray-500 text-sm">— each code redirects only once</span></span>
                    </label>
                    @if (_provisionError is not null)
                    {
                        <div class="text-red-600 text-sm mb-2" data-testid="provision-error">@_provisionError</div>
                    }
                    <div>
                        <button type="submit" class="btn btn-primary" data-testid="provision-submit">Provision codes</button>
                    </div>
                </EditForm>

                @if (_minted.Count > 0)
                {
                    <div class="alert alert-success mt-3" data-testid="minted">
                        <div class="flex items-center mb-2">
                            <span class="font-semibold">@_minted.Count code(s) ready.</span>
                            <button class="btn btn-outline-success ml-auto" @onclick="CopyAllMinted">Copy all</button>
                        </div>
                        <ul class="text-sm font-mono space-y-0.5">
                            @foreach (var m in _minted)
                            {
                                <li>@(m.Recipient ?? "—") → <a class="text-blue-700 hover:underline" href="@m.Url" target="_blank" rel="noopener">@m.Url</a></li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>

        <h5 class="text-base font-semibold mb-2">User Code Analytics</h5>
        @if (_userRows.Count == 0)
        {
            <p class="text-gray-500">No user codes provisioned yet.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                <tr><th>Recipient</th><th>Code</th><th class="text-right">Clicks</th><th>QR</th></tr>
                </thead>
                <tbody>
                @foreach (var r in _userRows)
                {
                    <tr>
                        <td>@(r.Recipient ?? "—") @if (r.IsOneTimeUse) { <span class="badge badge-yellow">one-time</span> }</td>
                        <td><code>@r.Code</code></td>
                        <td class="text-right">@r.Clicks</td>
                        <td class="whitespace-nowrap text-sm">
                            <a class="text-blue-700 hover:underline" href="/qr/@Id?format=png&code=@r.Code" download data-testid="qr-code-png">PNG</a>
                            <span class="text-gray-300">·</span>
                            <a class="text-blue-700 hover:underline" href="/qr/@Id?format=svg&code=@r.Code" download>SVG</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    }

    <ClicksTable Clicks="_clicks" />
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;
    [Parameter] public Guid Id { get; set; }

    bool _loaded, _notFound;
    bool _authResolved, _isSuperAdmin;
    Guid _uid;
    LinkEntity? _link;
    string _shortCode = string.Empty;
    string _shortUrl = string.Empty;
    bool _shortUrlCopied;
    List<ClickRow> _clicks = [];
    List<UserCodeRow> _userRows = [];
    ClickBreakdown? _breakdown;

    // Custom-domain pinning (current-account links only).
    bool _canPin, _pinSaved;
    Guid _accountId;
    List<DomainOption> _verifiedDomains = [];
    string _selectedDomainKey = string.Empty;

    // Campaign assignment (current-account links only).
    bool _campaignSaved;
    List<CampaignOption> _campaignOptions = [];
    string _selectedCampaignKey = string.Empty;

    // Social publishing (anonymous links in the current account).
    bool _busyPublishing;
    bool _busyMetrics;
    string? _publishText;
    readonly HashSet<Guid> _publishTargets = [];
    List<SocialConnectionRow> _socialConnections = [];
    List<PublishResultRow> _publishResults = [];
    List<SocialPostRow> _posts = [];

    protected override async Task OnParametersSetAsync()
    {
        if (!_authResolved)
        {
            var principal = (await AuthState).User;
            _isSuperAdmin = principal.IsSuperAdmin();
            var userId = principal.GetUserId();
            if (userId is null) { _notFound = true; _loaded = true; return; }
            _uid = userId.Value;
            await using (var db = await DbFactory.CreateDbContextAsync())
                _accountId = await AccountResolver.ResolveAccountIdAsync(db, _uid, principal.GetAccountId(), principal.Identity?.Name ?? "Personal");
            _authResolved = true;
        }
        await LoadAsync();
    }

    async Task LoadAsync()
    {
        _loaded = false;
        _notFound = false;
        _breakdown = null;
        _clicks = [];
        _shortUrl = string.Empty;
        _shortUrlCopied = false;

        await using var db = await DbFactory.CreateDbContextAsync();

        _link = await db.LinkEntities
            .Include(l => l.ApiKey)
            .FirstOrDefaultAsync(l => l.Id == Id);

        if (_link is null) { _notFound = true; _loaded = true; return; }

        // Ownership: members may only view links in their account; super-admins may view any.
        // Report "not found" (not "forbidden") so existence isn't leaked.
        if (!_isSuperAdmin && _link.AccountId != _accountId)
        {
            _link = null;
            _notFound = true;
            _loaded = true;
            return;
        }

        if (_link.Mode == LinkMode.Anonymous)
        {
            var sc = await db.ShortCodeEntities.FirstOrDefaultAsync(s => s.LinkId == Id);
            _shortCode = sc?.Code ?? string.Empty;

            if (sc is not null)
            {
                _shortUrl = await ShortUrlBuilder.BuildAsync(db, _link, sc.Code, DashboardOpts.Value.PublicBaseUrl);
                var raw = await db.VisitEntities.Where(v => v.ShortCodeId == sc.Id)
                    .Select(v => new { v.HashedIp, v.Source, v.Device, v.ClickedAt, v.ReferrerHost, v.Browser, v.Os, v.Country, v.Language, v.NavigationType })
                    .ToListAsync();
                _breakdown = ClickAggregator.Summarize(
                    raw.Select(v => new VisitRow(v.HashedIp, v.Source, v.Device, v.ClickedAt, v.Browser, v.Os, v.Country, v.Language, v.NavigationType)).ToList());
                _clicks = raw.Select(v => new ClickRow(v.ClickedAt, v.Source, v.Device, v.ReferrerHost, v.Browser, v.Os, v.Country, v.Language)).ToList();
            }
        }
        else
        {
            var codes = await db.UserLinkCodeEntities
                .Where(c => c.LinkId == Id)
                .OrderByDescending(c => c.Id)
                .ToListAsync();

            var codeIds = codes.Select(c => c.Id).ToList();
            var clicks = await db.UserVisitEntities
                .Where(v => codeIds.Contains(v.UserLinkCodeId))
                .GroupBy(v => v.UserLinkCodeId)
                .Select(g => new { Id = g.Key, Count = g.Count() })
                .ToListAsync();

            var clickMap = clicks.ToDictionary(x => x.Id, x => x.Count);
            _userRows = codes.Select(c => new UserCodeRow(c.Code, c.Recipient, c.IsOneTimeUse,
                clickMap.GetValueOrDefault(c.Id, 0))).ToList();

            var raw = await db.UserVisitEntities.Where(v => codeIds.Contains(v.UserLinkCodeId))
                .Select(v => new { v.HashedIp, v.Source, v.Device, v.ClickedAt, v.ReferrerHost, v.Browser, v.Os, v.Country, v.Language, v.NavigationType })
                .ToListAsync();
            _breakdown = ClickAggregator.Summarize(
                raw.Select(v => new VisitRow(v.HashedIp, v.Source, v.Device, v.ClickedAt, v.Browser, v.Os, v.Country, v.Language, v.NavigationType)).ToList());
            _clicks = raw.Select(v => new ClickRow(v.ClickedAt, v.Source, v.Device, v.ReferrerHost, v.Browser, v.Os, v.Country, v.Language)).ToList();
        }

        // Pinning is offered for links in the current account (not when a super-admin views another's).
        _canPin = _link.AccountId == _accountId;
        if (_canPin)
        {
            _verifiedDomains = await db.CustomDomainEntities
                .Where(d => d.AccountId == _accountId && d.VerificationStatus == DomainVerificationStatus.Verified)
                .OrderBy(d => d.Domain)
                .Select(d => new DomainOption(d.Id, d.Domain))
                .ToListAsync();
            _selectedDomainKey = _link.CustomDomainId?.ToString() ?? string.Empty;

            _campaignOptions = await db.CampaignEntities
                .Where(c => c.AccountId == _accountId)
                .OrderBy(c => c.Name)
                .Select(c => new CampaignOption(c.Id, c.Name))
                .ToListAsync();
            _selectedCampaignKey = _link.CampaignId?.ToString() ?? string.Empty;

            if (_link.Mode == LinkMode.Anonymous)
            {
                _socialConnections = await db.SocialConnectionEntities
                    .Where(c => c.AccountId == _accountId)
                    .OrderBy(c => c.Handle)
                    .Select(c => new SocialConnectionRow(c.Id, c.Platform.ToString(), c.Handle))
                    .ToListAsync();
                _posts = await db.SocialPostEntities
                    .Where(p => p.LinkId == Id)
                    .OrderByDescending(p => p.Id)
                    .Select(p => new SocialPostRow(p.Platform.ToString(), p.Handle, p.PostedAt, p.PostUrl, p.Likes, p.Reposts, p.Replies, p.Impressions))
                    .ToListAsync();
            }
        }

        _loaded = true;
    }

    async Task RefreshMetricsAsync()
    {
        _busyMetrics = true;
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var metrics = scope.ServiceProvider.GetRequiredService<ISocialMetricsService>();
            await metrics.RefreshLinkAsync(_accountId, Id);
            await LoadAsync();
        }
        finally { _busyMetrics = false; }
    }

    void ToggleTarget(Guid connectionId, bool selected)
    {
        if (selected) _publishTargets.Add(connectionId);
        else _publishTargets.Remove(connectionId);
    }

    async Task PublishAsync()
    {
        if (_publishTargets.Count == 0 || string.IsNullOrEmpty(_shortUrl)) return;
        _busyPublishing = true;
        _publishResults = [];
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var publisher = scope.ServiceProvider.GetRequiredService<ISocialPublishService>();
            var results = await publisher.PublishLinkAsync(_accountId, Id, [.. _publishTargets], _publishText, _shortUrl);
            _publishResults = results
                .Select(r => new PublishResultRow(r.Handle, r.Success, r.Post?.PostUrl, r.Error))
                .ToList();
            if (results.Any(r => r.Success))
            {
                _publishText = null;
                _publishTargets.Clear();
                await LoadAsync(); // refresh the published-posts table; per-target results stay visible
            }
        }
        catch (ShortLynx.Services.Entitlements.EntitlementException ex)
        {
            _publishResults = [new PublishResultRow("plan", false, null, ex.Message)];
        }
        finally { _busyPublishing = false; }
    }

    sealed record SocialConnectionRow(Guid Id, string Platform, string Handle);
    sealed record PublishResultRow(string Handle, bool Success, string? PostUrl, string? Error);
    sealed record SocialPostRow(string Platform, string Handle, DateTimeOffset PostedAt, string? PostUrl, long? Likes, long? Reposts, long? Replies, long? Impressions);

    async Task SaveCampaign()
    {
        if (!_canPin) return;
        _campaignSaved = false;
        Guid? campaignId = Guid.TryParse(_selectedCampaignKey, out var id) ? id : null;

        await using var scope = ScopeFactory.CreateAsyncScope();
        var svc = scope.ServiceProvider.GetRequiredService<ILinkService>();
        if (await svc.SetLinkCampaignAsync(Id, campaignId, _accountId))
        {
            _campaignSaved = true;
            await LoadAsync();
        }
    }

    sealed record CampaignOption(Guid Id, string Name);

    async Task SavePin()
    {
        if (!_canPin) return;
        _pinSaved = false;
        Guid? domainId = Guid.TryParse(_selectedDomainKey, out var id) ? id : null;

        await using var scope = ScopeFactory.CreateAsyncScope();
        var svc = scope.ServiceProvider.GetRequiredService<ILinkService>();
        if (await svc.SetLinkDomainAsync(Id, domainId, _accountId))
        {
            _pinSaved = true;
            await LoadAsync();
        }
    }

    sealed record DomainOption(Guid Id, string Domain);

    // ── Code provisioning (Mode 2) ────────────────────────────────────────────

    readonly ProvisionForm _provision = new();
    string? _provisionError;
    List<MintedCode> _minted = [];

    async Task ProvisionCodes()
    {
        _provisionError = null;

        var recipients = (_provision.Recipients ?? string.Empty)
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(label => new CodeRecipient(Guid.CreateVersion7(), label))
            .ToList();

        if (recipients.Count == 0)
        {
            _provisionError = "Enter at least one recipient.";
            return;
        }

        await using var scope = ScopeFactory.CreateAsyncScope();
        var svc = scope.ServiceProvider.GetRequiredService<ILinkService>();
        var codes = await svc.CreateUserLinkCodesAsync(Id, recipients, _provision.IsOneTimeUse);

        var baseUrl = DashboardOpts.Value;
        _minted = codes.Select(c => new MintedCode(c.Recipient, baseUrl.BuildShortUrl(c.Code))).ToList();
        _provision.Recipients = string.Empty;
        await LoadAsync();
    }

    async Task CopyAllMinted()
    {
        var text = string.Join('\n', _minted.Select(m => m.Url));
        await JS.InvokeVoidAsync("shortlynxCopy", text);
    }

    async Task CopyShortUrl()
    {
        if (string.IsNullOrEmpty(_shortUrl)) return;
        await JS.InvokeVoidAsync("shortlynxCopy", _shortUrl);
        _shortUrlCopied = true;
    }

    sealed class ProvisionForm
    {
        public string? Recipients { get; set; }
        public bool IsOneTimeUse { get; set; }
    }

    sealed record MintedCode(string? Recipient, string Url);

    sealed record UserCodeRow(string Code, string? Recipient, bool IsOneTimeUse, int Clicks);
}
