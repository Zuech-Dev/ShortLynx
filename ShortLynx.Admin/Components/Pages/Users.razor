@page "/users"
@attribute [Authorize(Policy = AdminClaims.SuperAdminPolicy)]
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.DependencyInjection
@using ShortLynx.Services.Accounts
@inject IDbContextFactory<ShortLynxDbContext> DbFactory
@inject IServiceScopeFactory ScopeFactory

<PageTitle>Users — ShortLynx Admin</PageTitle>

<div class="flex justify-between items-center mb-4">
    <h1 class="text-2xl font-bold">Users</h1>
    <button class="btn btn-primary" @onclick="() => _showCreate = !_showCreate">
        @(_showCreate ? "Cancel" : "+ New account")
    </button>
</div>

@if (_showCreate)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Create an account</h5>
            <p class="text-gray-500 text-sm">Creates a new account scoped to its own context, with the given owner. The
                owner gets a sign-in email.</p>
            <EditForm Model="_createForm" OnValidSubmit="CreateAccount">
                <DataAnnotationsValidator/>
                <div class="flex flex-wrap gap-2 items-end">
                    <div>
                        <label class="field-label">Account name</label>
                        <InputText class="field-input" @bind-Value="_createForm.Name" placeholder="Acme Inc."
                                   data-testid="account-name"/>
                    </div>
                    <div>
                        <label class="field-label">Owner email</label>
                        <InputText class="field-input" @bind-Value="_createForm.OwnerEmail"
                                   placeholder="owner@example.com" data-testid="owner-email"/>
                    </div>
                    <button type="submit" class="btn btn-primary" data-testid="create-account-submit">Create account
                    </button>
                </div>
                <ValidationMessage For="() => _createForm.Name"/>
                <ValidationMessage For="() => _createForm.OwnerEmail"/>
                @if (_createdName is not null)
                {
                    <div class="text-green-700 text-sm mt-1" data-testid="account-created">Created '@_createdName' and
                        emailed the owner a sign-in link.
                    </div>
                }
            </EditForm>
        </div>
    </div>
}

@if (!_loaded)
{
    <p class="text-gray-500">Loading…</p>
}
else if (_rows.Count == 0)
{
    <p class="text-gray-500">No users yet.</p>
}
else
{
    <div class="overflow-x-auto">
        <table class="data-table">
            <thead>
            <tr>
                <th>Email</th>
                <th>Memberships</th>
                <th>Status</th>
                <th>Created</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var r in _rows)
            {
                <tr class="@(!r.IsActive ? "text-gray-400" : null)">
                    <td>@r.Email</td>
                    <td>@string.Join(", ", r.Accounts)</td>
                    <td>
                        @if (r.IsActive)
                        {
                            <span class="badge badge-green">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-gray">Inactive</span>
                        }
                    </td>
                    <td class="text-gray-500 text-sm whitespace-nowrap">@r.CreatedAt.ToString("yyyy-MM-dd")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="flex gap-2 mt-3">
        <button class="btn btn-outline" @onclick="PrevPage" disabled="@(_page == 1)">← Prev</button>
        <span class="self-center text-gray-500 text-sm">Page @_page</span>
        <button class="btn btn-outline" @onclick="NextPage" disabled="@(_rows.Count < PageSize)">Next →</button>
    </div>
}

@code {
    const int PageSize = 50;
    int _page = 1;
    bool _loaded;
    List<UserRow> _rows = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    async Task LoadAsync()
    {
        _loaded = false;
        await using var db = await DbFactory.CreateDbContextAsync();

        var users = await db.UserAccountEntities
                             .Include(u => u.Memberships)
                             .ThenInclude(m => m.Account)
                             .OrderByDescending(u => u.Id)
                             .Skip((_page - 1) * PageSize)
                             .Take(PageSize)
                             .ToListAsync();

        _rows = users.Select(u => new UserRow(u.Email, u.Memberships?.Count(m => !string.IsNullOrWhiteSpace(m.Account?.Id.ToString())) > 0 ? u.Memberships.Select(m => m.Account.Name) : ["SuperAdmin"], u.IsActive, u.CreatedAt)).ToList();
        _loaded = true;
    }

    async Task PrevPage()
    {
        if (_page > 1)
        {
            _page--;
            await LoadAsync();
        }
    }

    async Task NextPage()
    {
        _page++;
        await LoadAsync();
    }

    bool _showCreate;
    string? _createdName;
    readonly CreateAccountForm _createForm = new();

    async Task CreateAccount()
    {
        _createdName = null;
        await using var scope = ScopeFactory.CreateAsyncScope();
        var svc = scope.ServiceProvider.GetRequiredService<IAccountService>();
        var account = await svc.CreateAccountWithOwnerAsync(_createForm.Name!, _createForm.OwnerEmail!);
        _createdName = account.Name;
        _createForm.Name = string.Empty;
        _createForm.OwnerEmail = string.Empty;
        await LoadAsync();
    }

    sealed class CreateAccountForm
    {
        [Required(ErrorMessage = "Account name is required.")]
        public string? Name { get; set; }

        [Required(ErrorMessage = "Owner email is required."), EmailAddress]
        public string? OwnerEmail { get; set; }
    }

    sealed record UserRow(string Email, IEnumerable<string> Accounts, bool IsActive, DateTimeOffset CreatedAt);

}
